    bhDimSel.addEventListener('change', () => {
      bhState.driverDimension = bhDimSel.value;
      renderBHDriverTable(bhState.lastDrivers, bhState.driverDimension);
    });
  }
}

// Compute the start/end date window for Box Health charts/cards
function getBHDateWindow(boxTrend) {
  // Custom range: use user-picked dates directly
  if (bhState.bhDateDays === -1) {
    return { start: bhState.bhCustomStart || null, end: bhState.bhCustomEnd || null };
  }
  // All Time
  if (!bhState.bhDateDays) return { start: null, end: null };
  // Preset: go back bhDateDays from the most recent data week
  const weeks = [...new Set(boxTrend.map(r => r.week_start))].sort();
  if (!weeks.length) return { start: null, end: null };
  const end   = weeks[weeks.length - 1];
  const start = new Date(new Date(end + 'T00:00:00').getTime() - bhState.bhDateDays * 86400000)
    .toISOString().split('T')[0];
  return { start, end };
}

// Filter any boxHealth dataset (boxTrend, styleAccuracy, etc.) by week_start range
function filterBHByDate(rows, start, end) {
  if (!start && !end) return rows;
  return rows.filter(r => (!start || r.week_start >= start) && (!end || r.week_start <= end));
}

// Compute combined (new+rec) hate/love rates for a reference window — returns {hate_rate, love_rate, total} or null
function bhComputeRef(boxTrend, start, end) {
  let hate = 0, love = 0, total = 0;
  for (const r of boxTrend) {
    if (start && r.week_start < start) continue;
    if (end   && r.week_start > end)   continue;
    hate  += r.hate  || 0;
    love  += r.love  || 0;
    total += r.total || 0;
  }
  if (total < 30) return null;
  return { hate_rate: hate / total, love_rate: love / total, total };
}

// Compute per-customer-type reference rates
function bhComputeRefByCT(boxTrend, start, end, ct) {
  let hate = 0, love = 0, total = 0;
  for (const r of boxTrend) {
    if (start && r.week_start < start) continue;
    if (end   && r.week_start > end)   continue;
    if (r.customer_type !== ct) continue;
    hate  += r.hate  || 0;
    love  += r.love  || 0;
    total += r.total || 0;
  }
  if (total < 30) return null;
  return { hate_rate: hate / total, love_rate: love / total, total };
}

// Format a delta badge for Box Health cards
function formatBHDelta(curRate, refRate, label, invertColor = false) {
  if (refRate == null) return '';
  const pp = (curRate - refRate) * 100;
  if (Math.abs(pp) < 0.05) return '';
  const goingUp = pp > 0;
  const isBad   = invertColor ? !goingUp : goingUp;
  const cls     = isBad ? 'delta--up' : 'delta--down';
  const arrow   = goingUp ? '▲' : '▼';
  const sign    = goingUp ? '+' : '';
  return `<span class="delta-badge ${cls}">${arrow} ${sign}${pp.toFixed(1)}pp <span class="delta-label">${label}</span></span>`;
}

// Orchestrate all Box Health renders.
// Date range selector affects ONLY the summary cards — charts always show full history.
function renderBoxHealthAll(data) {
  const { start, end } = getBHDateWindow(data.boxTrend);
  // Cards: scoped to selected date window
  renderBHCards(data.boxTrend, start, end);
  // Charts: always full history (Jan 2025 → present)
  renderBHTrendChart(data.boxTrend);
  renderBHStyleChart(data.styleAccuracy,   bhState.styleSentiment);
  renderBHValueChart(data.valuePerception, bhState.valueSentiment);
  renderBHFitChart(data.fitSignal);
  renderBHDistChart(data.boxTrend, bhState.distCustomerType);
}

// Main loader — fetches /api/box-health and renders everything
async function loadBoxHealth() {
  try {
