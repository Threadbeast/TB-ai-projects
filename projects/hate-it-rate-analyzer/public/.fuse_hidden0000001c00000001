// ============================================================

const reportState = {
  dateDays:    30,    // default: 1 month; 0 = all time; -1 = custom
  customStart: null,
  customEnd:   null
};

function getReportDateRange() {
  if (reportState.dateDays === -1) {
    return { start: reportState.customStart || null, end: reportState.customEnd || null };
  }
  if (!reportState.dateDays) return { start: null, end: null };
  // Compute from today backwards
  const end   = new Date().toISOString().split('T')[0];
  const start = new Date(Date.now() - reportState.dateDays * 86400000).toISOString().split('T')[0];
  return { start, end };
}

function setupReportControls() {
  document.querySelectorAll('.report-range-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.report-range-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const customPanel = document.getElementById('reportCustomRange');
      if (btn.dataset.days === 'custom') {
        reportState.dateDays = -1;
        if (customPanel) customPanel.style.display = 'flex';
      } else {
        reportState.dateDays   = parseInt(btn.dataset.days) || 0;
        reportState.customStart = null;
        reportState.customEnd   = null;
        if (customPanel) customPanel.style.display = 'none';
      }
    });
  });

  document.getElementById('reportCustomStart')?.addEventListener('change', (e) => {
    reportState.customStart = e.target.value || null;
  });
  document.getElementById('reportCustomEnd')?.addEventListener('change', (e) => {
    reportState.customEnd = e.target.value || null;
  });
}
