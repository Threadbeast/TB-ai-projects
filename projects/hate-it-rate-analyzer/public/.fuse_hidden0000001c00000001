  html += `<div style="padding:6px 8px;color:var(--text-muted);font-size:10px;font-weight:600;">
    Brand ↓ &nbsp;/&nbsp; Category →</div>`;
  for (const cat of categories) {
    html += `<div style="padding:4px 3px;color:var(--text-muted);text-align:center;font-size:10px;
      white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="${escapeHtml(cat)}">${escapeHtml(cat)}</div>`;
  }

  // Data rows — one per brand
  for (const brand of brands) {
    const escapedBrand = escapeAttr(brand);
    html += `<div style="padding:6px 8px;color:var(--text-primary);font-size:11px;font-weight:500;
      white-space:nowrap;overflow:hidden;text-overflow:ellipsis;cursor:pointer;border-radius:3px;transition:background 0.15s;"
      onclick="drillDown('product_brand','${escapedBrand}','product_category')"
      onmouseover="this.style.background='rgba(0,180,255,0.1)'"
      onmouseout="this.style.background=''"
      title="${escapeHtml(brand)} — click to drill into categories">${escapeHtml(brand)}</div>`;

    for (const cat of categories) {
      const cell = lookup[brand]?.[cat];
      if (!cell) {
        html += `<div style="background:rgba(10,15,25,0.4);border-radius:3px;"></div>`;
      } else {
        const bg      = cellBg(cell.hateRate);
        const ratePct = (cell.hateRate * 100).toFixed(1);
        const txtClr  = cell.hateRate > 0.17 ? '#fff' : '#8899b3';
        const fw      = cell.hateRate > 0.15 ? 600 : 400;
        const esc     = escapeAttr(cat);
        html += `<div style="background:${bg};border-radius:3px;padding:5px 3px;text-align:center;
          color:${txtClr};font-weight:${fw};cursor:pointer;transition:filter 0.1s;"
          onclick="drillDown('product_brand','${escapedBrand}','product_category')"
          onmouseover="this.style.filter='brightness(1.3)'"
          onmouseout="this.style.filter=''"
          title="${escapeHtml(brand)} × ${escapeHtml(cat)}: ${ratePct}% hate (${cell.total} items)">${ratePct}%</div>`;
      }
    }
  }
  html += '</div>';

  // Legend
  html += `<div style="display:flex;align-items:center;gap:12px;margin-top:10px;font-size:11px;color:var(--text-muted);flex-wrap:wrap;">
    <span>Hate Rate:</span>
    <div style="display:flex;align-items:center;gap:4px;">
      <div style="width:28px;height:13px;background:rgba(20,35,55,0.25);border-radius:2px;border:1px solid rgba(106,136,176,0.2);"></div><span>0%</span>
    </div>
    <div style="display:flex;align-items:center;gap:4px;">
      <div style="width:28px;height:13px;background:rgba(88,18,28,0.75);border-radius:2px;"></div><span>12%</span>
    </div>
    <div style="display:flex;align-items:center;gap:4px;">
      <div style="width:28px;height:13px;background:rgba(155,0,0,0.95);border-radius:2px;"></div><span>25%+</span>
    </div>
    <span style="margin-left:4px;">⬛ = no data / &lt;3 items &nbsp;·&nbsp; Click brand row or cell → drill into categories</span>
  </div>`;

  container.innerHTML = html;
