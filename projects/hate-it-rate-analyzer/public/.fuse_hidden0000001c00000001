// ============================================================
// WEEK LABEL UTILITIES
// ============================================================

const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

/**
 * Format a week label from its start-date string.
 * The start date is whatever the backend sends (currently Monday-aligned).
 * Returns e.g. "Mar 2–8", "Mar 30–Apr 5", "Mar 23–29 (in progress)"
 */
function formatWeekLabel(weekStartStr) {
  // Parse as local midnight to avoid UTC-offset day shifts
  const start = new Date(weekStartStr + 'T00:00:00');
  const end   = new Date(weekStartStr + 'T00:00:00');
  end.setDate(start.getDate() + 6);

  const today = new Date();
  today.setHours(0, 0, 0, 0);

  const label = start.getMonth() === end.getMonth()
    ? `${MONTHS[start.getMonth()]} ${start.getDate()}–${end.getDate()}`
    : `${MONTHS[start.getMonth()]} ${start.getDate()}–${MONTHS[end.getMonth()]} ${end.getDate()}`;

  // Append "(in progress)" if today falls within this week
  return (today >= start && today <= end) ? label + ' (in progress)' : label;
}

/**
 * Snap a date string to a Sun–Sat week boundary.
 * direction='start' → back to nearest Sunday
 * direction='end'   → forward to nearest Saturday
 */
function snapToWeekBoundary(dateStr, direction) {
  const d = new Date(dateStr + 'T00:00:00');
  const day = d.getDay(); // 0=Sun … 6=Sat
  if (direction === 'start') {
    d.setDate(d.getDate() - day);           // back to Sunday
  } else {
    d.setDate(d.getDate() + (6 - day));     // forward to Saturday
  }
  return d.toISOString().split('T')[0];
}

