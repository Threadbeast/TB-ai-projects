// --- Chart 1: Box Hate & Love Rate Trend ---
function renderBHTrendChart(boxTrend) {
  const ctx = document.getElementById('bhTrendChart').getContext('2d');
  if (bhState.charts.trend) bhState.charts.trend.destroy();

  const weeksSet = new Set(boxTrend.map(r => r.week_start));
  const weeks    = [...weeksSet].sort();
  const lookup   = {};
  for (const r of boxTrend) {
    if (!lookup[r.week_start]) lookup[r.week_start] = {};
    lookup[r.week_start][r.customer_type] = r;
  }
  const labels = weeks.map(w => formatWeekLabel(w));
  const pct = (w, ct, field) => lookup[w]?.[ct] ? +(lookup[w][ct][field] * 100).toFixed(2) : null;

  bhState.charts.trend = new Chart(ctx, {
    type: 'line',
    data: { labels, datasets: [
      bhLineDataset('New — Hate Rate',       weeks.map(w => pct(w,'new','hate_rate')),       'rgba(255,45,45,0.9)',  false),
      bhLineDataset('Recurring — Hate Rate', weeks.map(w => pct(w,'recurring','hate_rate')), 'rgba(255,45,45,0.55)', true),
      bhLineDataset('New — Love Rate',       weeks.map(w => pct(w,'new','love_rate')),       'rgba(0,230,118,0.9)',  false),
      bhLineDataset('Recurring — Love Rate', weeks.map(w => pct(w,'recurring','love_rate')), 'rgba(0,230,118,0.55)', true),
    ]},
    options: {
      ...BH_CHART_DEFAULTS,
      plugins: { ...BH_CHART_DEFAULTS.plugins, tooltip: { callbacks: {
        title: items => items.length ? formatWeekLabel(weeks[items[0].dataIndex]) : '',
        afterBody: items => {
          const i = items[0]?.dataIndex;
          if (i == null) return [];
          const n = lookup[weeks[i]]?.new, r = lookup[weeks[i]]?.recurring;
          return [
            n ? `New: ${n.hate} hate / ${n.love} love / ${n.total} total` : '',
            r ? `Recurring: ${r.hate} hate / ${r.love} love / ${r.total} total` : ''
          ].filter(Boolean);
        }
      }}}
    }
  });

  const container = document.getElementById('bhTrendChart').closest('.chart-container');
  removeExplainer(container);
  container.insertAdjacentHTML('beforeend', `<div class="explainer">
    <strong>What this shows:</strong> Box hate and love rates week over week, split by new vs recurring customers.
    Solid lines = New customers. Dashed lines = Recurring customers.
    <br><br>
    <strong>Key insight:</strong> If new customer hate rate spikes but recurring stays flat, the problem is likely in onboarding or first-box curation — not product quality overall.
    If both spike together, it's a broader product or value issue.
  </div>`);
}

// Shared stacked bar builder for Style Accuracy and Value Perception
function buildStackedBarChart(canvasId, rows, weeks, lookup, datasetDefs, chartRef) {
  const ctx = document.getElementById(canvasId).getContext('2d');
  if (bhState.charts[chartRef]) bhState.charts[chartRef].destroy();

  const labels = weeks.map(w => formatWeekLabel(w));

  // Combine new + recurring into a single weighted-average value per week
  const getDataCombined = (field) => weeks.map(w => {
    const nr = lookup[w]?.['new'];
    const rr = lookup[w]?.['recurring'];
    if (!nr && !rr) return null;
    if (!nr) return +(rr[field] * 100).toFixed(1);
    if (!rr) return +(nr[field] * 100).toFixed(1);
    const totalN = nr.total_boxes || 0;
    const totalR = rr.total_boxes || 0;
    const total  = totalN + totalR;
    if (total === 0) return null;
    return +((nr[field] * totalN + rr[field] * totalR) / total * 100).toFixed(1);
  });

  const datasets = datasetDefs.map(({ label, field, newColor }) => ({
    label,
    stack: 'combined',
    data: getDataCombined(field),
    backgroundColor: newColor,
    borderWidth: 0
  }));

  bhState.charts[chartRef] = new Chart(ctx, {
    type: 'bar',
    data: { labels, datasets },
    options: {
      ...BH_CHART_DEFAULTS,
      scales: {
        x: { stacked: true, ticks: { color: '#6a88b0', font: { size: 10 }, maxRotation: 45, maxTicksLimit: 18 }, grid: { display: false } },
        y: { stacked: true, beginAtZero: true, max: 100, ticks: { callback: v => v + '%', color: '#6a88b0', font: { size: 11 } }, grid: { color: 'rgba(0,180,255,0.06)' } }
      },
      plugins: { ...BH_CHART_DEFAULTS.plugins, tooltip: { callbacks: {
        title: items => items.length ? formatWeekLabel(weeks[items[0].dataIndex]) : '',
        label: ctx => ctx.parsed.y != null ? `${ctx.dataset.label}: ${ctx.parsed.y.toFixed(1)}%` : null
      }}}
    }
  });
}

