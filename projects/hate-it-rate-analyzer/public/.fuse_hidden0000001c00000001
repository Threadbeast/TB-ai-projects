const lagState = {
  selectedWeeks: [],
  lagWindow:     14,
  customerType:  'all',
  chart:         null,
  lastData:      null,
  loaded:        false
};

// One color per ship week line (up to 4)
const LAG_LINE_COLORS = [
  { border: 'rgba(255,45,45,0.9)',   bg: 'rgba(255,45,45,0.07)'   },
  { border: 'rgba(0,180,255,0.9)',   bg: 'rgba(0,180,255,0.07)'   },
  { border: 'rgba(255,179,0,0.9)',   bg: 'rgba(255,179,0,0.07)'   },
  { border: 'rgba(0,230,118,0.9)',   bg: 'rgba(0,230,118,0.07)'   },
];

// Wire all controls inside the lag sub-panel
function setupLagControls() {
  // Lag window preset buttons
  document.querySelectorAll('.lag-window-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.lag-window-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      lagState.lagWindow = parseInt(btn.dataset.days);
      if (lagState.loaded) loadLagAnalysis();
    });
  });

  // Customer type filter buttons
  document.querySelectorAll('.lag-ctype-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.lag-ctype-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      lagState.customerType = btn.dataset.ctype;
      lagState.loaded = false; // force re-fetch so availableWeeks updates
      loadLagAnalysis();
    });
  });

  // Ship week multi-select
  const sel = document.getElementById('lagWeekSelect');
  if (sel) {
    sel.addEventListener('change', () => {
      // Enforce max 4 selections — keep first 4 chosen
      const selected = [...sel.selectedOptions].map(o => o.value).slice(0, 4);
      // Enforce the cap: deselect anything beyond 4
      let count = 0;
      for (const opt of sel.options) {
        if (opt.selected) {
          count++;
          if (count > 4) opt.selected = false;
        }
      }
      lagState.selectedWeeks = selected;
      if (lagState.loaded) loadLagAnalysis();
    });
  }
}

// Main lag loader — fetches /api/lag-analysis and renders all three sections
async function loadLagAnalysis() {
  const params = new URLSearchParams({
    lagWindow:    lagState.lagWindow,
    customerType: lagState.customerType,
  });
  if (lagState.selectedWeeks.length > 0) {
    params.set('weeks', lagState.selectedWeeks.join(','));
  }
  try {
    const res = await fetch(`${API_BASE}/lag-analysis?${params}`);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const data = await res.json();
    lagState.lastData = data;
    lagState.loaded   = true;
    lagState.selectedWeeks = data.selectedWeeks;
    populateLagWeekSelector(data.availableWeeks, data.selectedWeeks);
    renderLagCurve(data);
    renderLagHeatmap(data);
    renderLagTable(data);
  } catch (e) {
    console.error('Lag analysis load failed:', e.message);
  }
}

// Populate the ship week <select multiple> — only rebuild if list changed
function populateLagWeekSelector(availableWeeks, selectedWeeks) {
  const sel = document.getElementById('lagWeekSelect');
  if (!sel) return;
  const needsRebuild = sel.options.length !== availableWeeks.length
    || (sel.options[0] && sel.options[0].disabled);
  if (needsRebuild) {
    sel.innerHTML = availableWeeks.map(wk =>
      `<option value="${wk}">${formatWeekLabel(wk)}</option>`
    ).join('');
  }
  for (const opt of sel.options) {
    opt.selected = selectedWeeks.includes(opt.value);
  }
}

// ---- Section 1: Lag Curve (Chart.js line chart) ----
function renderLagCurve(data) {
  const canvas = document.getElementById('lagCurveChart');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (lagState.chart) lagState.chart.destroy();

  const { lagCurve, selectedWeeks, lagWindow, medianDaysToRate } = data;
  const days = Array.from({ length: lagWindow }, (_, i) => i + 1);

  // Keep raw bucket counts for richer tooltips
  const rawBuckets = {};

  const datasets = selectedWeeks.map((wk, idx) => {
    const byDay = lagCurve[wk] || {};
    rawBuckets[wk] = byDay;
    const c = LAG_LINE_COLORS[idx] || LAG_LINE_COLORS[0];
    return {
      label: formatWeekLabel(wk),
      _wk:   wk,
      data:  days.map(d => {
        const b = byDay[d];
        if (!b || b.total < 30) return null; // low-vol → break line
        return +(b.hate / b.total * 100).toFixed(1);
      }),
      borderColor:     c.border,
      backgroundColor: c.bg,
      borderWidth: 2,
      pointRadius: 3,
      pointHoverRadius: 5,
      tension: 0.3,
      spanGaps: false,
      fill: false,
    };
  });

  // Inline plugin: dashed vertical line at median days-to-rate
  const medianPlugin = {
    id: 'lagMedianLine',
    afterDraw(chart) {
      const med = medianDaysToRate;
      if (!med || med < 1 || med > lagWindow) return;
      const xAxis = chart.scales.x;
      const tickIdx = med - 1;
      if (tickIdx >= days.length) return;
      const x  = xAxis.getPixelForTick(tickIdx);
      const { top, bottom } = chart.chartArea;
      const c  = chart.ctx;
      c.save();
      c.strokeStyle = 'rgba(255,179,0,0.65)';
      c.lineWidth   = 1.5;
      c.setLineDash([6, 4]);
      c.beginPath();
      c.moveTo(x, top);
      c.lineTo(x, bottom);
      c.stroke();
      c.setLineDash([]);
      c.fillStyle  = 'rgba(255,179,0,0.8)';
      c.font       = '10px Inter, sans-serif';
      c.fillText(`Median: Day ${med}`, x + 4, top + 14);
      c.restore();
    }
  };

  lagState.chart = new Chart(ctx, {
    type: 'line',
    data: { labels: days.map(d => `Day ${d}`), datasets },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: {
          display: true, position: 'top', align: 'end',
          labels: { color: '#6a88b0', font: { size: 10 }, boxWidth: 20, padding: 10, usePointStyle: true }
        },
        tooltip: {
          callbacks: {
            label: (ctx) => {
              const wk     = ctx.dataset._wk;
              const bucket = rawBuckets[wk]?.[ctx.dataIndex + 1];
              if (ctx.parsed.y == null) {
                if (bucket && bucket.total > 0)
                  return `${ctx.dataset.label}: low vol (${bucket.total} boxes)`;
                return `${ctx.dataset.label}: no data`;
              }
              const n = bucket ? ` · ${bucket.total} boxes` : '';
              return `${ctx.dataset.label}: ${ctx.parsed.y.toFixed(1)}%${n}`;
            }
          }
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          min: 0,
          ticks: { callback: v => v + '%', color: '#6a88b0', font: { size: 11 } },
          grid:  { color: 'rgba(0,180,255,0.06)' },
          title: { display: true, text: 'Box Hate Rate %', color: '#6a88b0', font: { size: 11 } }
        },
        x: {
          ticks: { color: '#6a88b0', font: { size: 10 } },
          grid:  { color: 'rgba(0,180,255,0.04)' },
          title: { display: true, text: 'Days Since Ship Date', color: '#6a88b0', font: { size: 11 } }
        }
      }
    },
    plugins: [medianPlugin]
  });

  const container = canvas.closest('.chart-container');
  removeExplainer(container);
  container.insertAdjacentHTML('beforeend', `<div class="explainer">
    <strong>What this shows:</strong> Each line shows how hate rates developed over time after boxes shipped that week.
    If hate peaks at Day 14, you have roughly a 2-week feedback delay to factor into your analysis.
    Compare multiple ship weeks to spot which batches performed differently.
    <br><br>
    <strong>Note:</strong> Points with fewer than 30 boxes are not plotted — the line breaks where volume is too low to trust.
    The gold dashed line marks the median days-to-rate across all boxes (Day ${medianDaysToRate}).
  </div>`);
}

// ---- Section 2: Ship Week × Rating Week Heatmap (HTML/CSS grid) ----
function renderLagHeatmap(data) {
  const container = document.getElementById('lagHeatmap');
  if (!container) return;

  const { heatmap, shipWeeks, ratingWeeks } = data;
  if (!shipWeeks.length || !ratingWeeks.length) {
    container.innerHTML = '<p style="color:var(--text-muted);padding:16px;">No heatmap data available for this selection.</p>';
    return;
  }

  // Map hate rate (0–0.30) → dark-navy to dark-red gradient
  function cellBg(rate) {
    const t = Math.min(rate / 0.30, 1);
    const r = Math.round(20  + t * (139 - 20));
    const g = Math.round(35  + t * (0   - 35));
    const b = Math.round(55  + t * (0   - 55));
    const a = (0.25 + t * 0.75).toFixed(2);
