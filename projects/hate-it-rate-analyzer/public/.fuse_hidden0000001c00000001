const itemLagState = {
  lagWindow:     14,
  customerType:  'all',
  selectedWeeks: [],
  loaded:        false,
  chart:         null,
  lastData:      null
};

function setupItemLagControls() {
  // Lag window buttons
  document.querySelectorAll('.il-window-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.il-window-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      itemLagState.lagWindow = parseInt(btn.dataset.days);
      if (itemLagState.loaded) loadItemLagAnalysis();
    });
  });

  // Customer type buttons
  document.querySelectorAll('.il-ctype-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.il-ctype-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      itemLagState.customerType = btn.dataset.ctype;
      if (itemLagState.loaded) loadItemLagAnalysis();
    });
  });

  // Ship week multi-select
  const sel = document.getElementById('ilWeekSelect');
  if (sel) {
    sel.addEventListener('change', () => {
      let count = 0;
      for (const opt of sel.options) {
        if (opt.selected) {
          count++;
          if (count > 4) opt.selected = false;
        }
      }
      itemLagState.selectedWeeks = [...sel.selectedOptions].map(o => o.value).slice(0, 4);
      if (itemLagState.loaded) loadItemLagAnalysis();
    });
  }
}

async function loadItemLagAnalysis() {
  // Dimension comes from the Item Health dimension select; default to brand
  const lagDim = state.dimension || 'product_brand';
  updateILDimLabel(lagDim);

  const params = new URLSearchParams({
    lagWindow:    itemLagState.lagWindow,
    customerType: itemLagState.customerType,
    dimension:    lagDim
  });
  if (itemLagState.selectedWeeks.length > 0) {
    params.set('weeks', itemLagState.selectedWeeks.join(','));
  }
  try {
    const res = await fetch(`${API_BASE}/item-lag-analysis?${params}`);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const data = await res.json();
    itemLagState.lastData      = data;
    itemLagState.loaded        = true;
    itemLagState.selectedWeeks = data.selectedWeeks;
    populateILWeekSelector(data.availableWeeks, data.selectedWeeks);
    renderItemLagCurve(data);
    renderItemLagHeatmap(data);
    renderItemLagTable(data);
    renderItemLagDimBreakdown(data, lagDim);
  } catch (e) {
    console.error('Item lag analysis load failed:', e.message);
  }
}

function updateILDimLabel(dim) {
  const label = document.getElementById('ilDimLabel');
  if (label) label.textContent = getDimensionLabel(dim || 'product_brand');
}

function populateILWeekSelector(availableWeeks, selectedWeeks) {
  const sel = document.getElementById('ilWeekSelect');
  if (!sel) return;
  const needsRebuild = sel.options.length !== availableWeeks.length
    || (sel.options[0] && sel.options[0].disabled);
  if (needsRebuild) {
    sel.innerHTML = availableWeeks.map(wk =>
      `<option value="${wk}">${formatWeekLabel(wk)}</option>`
    ).join('');
  }
  for (const opt of sel.options) {
    opt.selected = selectedWeeks.includes(opt.value);
  }
}

function renderItemLagCurve(data) {
  const canvas = document.getElementById('ilCurveChart');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (itemLagState.chart) itemLagState.chart.destroy();

  const { lagCurve, selectedWeeks, lagWindow, medianDaysToRate } = data;
  const days = Array.from({ length: lagWindow }, (_, i) => i + 1);
  const rawBuckets = {};

  const datasets = selectedWeeks.map((wk, idx) => {
    const byDay = lagCurve[wk] || {};
    rawBuckets[wk] = byDay;
    const c = LAG_LINE_COLORS[idx] || LAG_LINE_COLORS[0];
    return {
      label: formatWeekLabel(wk),
      _wk:   wk,
      data:  days.map(d => {
        const b = byDay[d];
        if (!b || b.total < 20) return null;
        return +(b.hate / b.total * 100).toFixed(1);
      }),
      borderColor:     c.border,
      backgroundColor: c.bg,
      borderWidth: 2,
      pointRadius: 3,
      pointHoverRadius: 5,
      tension: 0.3,
      spanGaps: false,
      fill: false,
    };
  });

  // Inline median-line plugin (same pattern as box lag)
  const medianPlugin = {
    id: 'ilMedianLine',
    afterDraw(chart) {
      const med = medianDaysToRate;
      if (!med || med < 1 || med > lagWindow) return;
      const xAxis   = chart.scales.x;
      const tickIdx = med - 1;
      if (tickIdx >= days.length) return;
      const x   = xAxis.getPixelForTick(tickIdx);
      const { top, bottom } = chart.chartArea;
      const c   = chart.ctx;
      c.save();
      c.strokeStyle = 'rgba(255,179,0,0.65)';
      c.lineWidth   = 1.5;
      c.setLineDash([6, 4]);
      c.beginPath();
      c.moveTo(x, top);
      c.lineTo(x, bottom);
      c.stroke();
      c.setLineDash([]);
      c.fillStyle = 'rgba(255,179,0,0.8)';
      c.font      = '10px Inter, sans-serif';
      c.fillText(`Median: Day ${med}`, x + 4, top + 14);
      c.restore();
    }
  };

  itemLagState.chart = new Chart(ctx, {
    type: 'line',
    data: { labels: days.map(d => `Day ${d}`), datasets },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: {
          display: true, position: 'top', align: 'end',
          labels: { color: '#6a88b0', font: { size: 10 }, boxWidth: 20, padding: 10, usePointStyle: true }
        },
        tooltip: {
          callbacks: {
            label: (ctx) => {
              const wk     = ctx.dataset._wk;
              const bucket = rawBuckets[wk]?.[ctx.dataIndex + 1];
              if (ctx.parsed.y == null) {
                if (bucket && bucket.total > 0)
                  return `${ctx.dataset.label}: low vol (${bucket.total} items)`;
                return `${ctx.dataset.label}: no data`;
              }
              const n = bucket ? ` · ${bucket.total} items` : '';
              return `${ctx.dataset.label}: ${ctx.parsed.y.toFixed(1)}%${n}`;
            }
          }
        }
      },
      scales: {
        y: {
          beginAtZero: true, min: 0,
          ticks: { callback: v => v + '%', color: '#6a88b0', font: { size: 11 } },
          grid:  { color: 'rgba(0,180,255,0.06)' },
          title: { display: true, text: 'Item Hate Rate %', color: '#6a88b0', font: { size: 11 } }
        },
        x: {
          ticks: { color: '#6a88b0', font: { size: 10 } },
          grid:  { color: 'rgba(0,180,255,0.04)' },
          title: { display: true, text: 'Days Since Ship Date', color: '#6a88b0', font: { size: 11 } }
        }
      }
    },
    plugins: [medianPlugin]
  });

  const container = canvas.closest('.chart-container');
  removeExplainer(container);
  container.insertAdjacentHTML('beforeend', `<div class="explainer">
    <strong>What this shows:</strong> Each line tracks how item hate rates developed over days after the ship week.
    Compare ship weeks to spot whether recent batches are performing differently from earlier ones.
    <br><br>
    <strong>Note:</strong> Points with fewer than 20 items are not plotted. The gold dashed line marks the median days-to-rate (Day ${medianDaysToRate}).
  </div>`);
}

function renderItemLagHeatmap(data) {
  const container = document.getElementById('ilHeatmap');
  if (!container) return;

  const { heatmap, shipWeeks, ratingWeeks } = data;
  if (!shipWeeks.length || !ratingWeeks.length) {
    container.innerHTML = '<p style="color:var(--text-muted);padding:16px;">No heatmap data available.</p>';
    return;
  }

  function cellBg(rate) {
    const t = Math.min(rate / 0.30, 1);
    const r = Math.round(20  + t * (139 - 20));
    const g = Math.round(35  + t * (0   - 35));
    const b = Math.round(55  + t * (0   - 55));
    const a = (0.25 + t * 0.75).toFixed(2);
    return `rgba(${r},${g},${b},${a})`;
  }

  const cellW  = 72;
  const labelW = 122;
  const gap    = 2;
  const cols   = ratingWeeks.length;

  let html = `<div style="
    display:grid;
    grid-template-columns:${labelW}px ${Array(cols).fill(cellW + 'px').join(' ')};
    gap:${gap}px;
    min-width:${labelW + cols * (cellW + gap)}px;
    font-size:11px;
  ">`;

  html += `<div style="padding:6px 8px;color:var(--text-muted);font-size:10px;font-weight:600;line-height:1.3;">
    Ship ↓ &nbsp;/&nbsp; Rating →</div>`;
  for (const rw of ratingWeeks) {
    html += `<div style="padding:4px 3px;color:var(--text-muted);text-align:center;font-size:10px;
      white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="${formatWeekLabel(rw)}">${formatWeekLabel(rw)}</div>`;
  }

  for (const sw of shipWeeks) {
    html += `<div style="padding:6px 8px;color:var(--text-primary);font-size:11px;font-weight:500;
      cursor:pointer;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
      border-radius:3px;transition:background 0.15s;"
      onclick="ilSelectWeek('${sw}')"
      onmouseover="this.style.background='rgba(0,180,255,0.1)'"
      onmouseout="this.style.background=''"
      title="Click to add to lag curve">${formatWeekLabel(sw)}</div>`;

    for (const rw of ratingWeeks) {
      const cell = heatmap[sw]?.[rw];
      if (!cell) {
        html += `<div style="background:rgba(10,15,25,0.5);border-radius:3px;"></div>`;
      } else if (cell.total < 20) {
        html += `<div style="background:rgba(40,55,70,0.5);border-radius:3px;padding:5px 3px;
          text-align:center;color:var(--text-muted);font-size:10px;" title="${cell.total} items">low vol</div>`;
      } else {
        const bg      = cellBg(cell.rate);
        const ratePct = (cell.rate * 100).toFixed(1);
        const txtClr  = cell.rate > 0.17 ? '#fff' : '#8899b3';
        const fw      = cell.rate > 0.15 ? 600 : 400;
        html += `<div style="background:${bg};border-radius:3px;padding:5px 3px;
          text-align:center;color:${txtClr};font-weight:${fw};cursor:pointer;transition:filter 0.1s;"
          onclick="ilSelectWeek('${sw}')"
          onmouseover="this.style.filter='brightness(1.3)'"
          onmouseout="this.style.filter=''"
          title="${cell.total} items | ${ratePct}% hate">${ratePct}%</div>`;
      }
    }
  }
  html += '</div>';

  html += `<div style="display:flex;align-items:center;gap:12px;margin-top:10px;
    font-size:11px;color:var(--text-muted);flex-wrap:wrap;">
    <span>Hate Rate:</span>
    <div style="display:flex;align-items:center;gap:4px;">
      <div style="width:28px;height:13px;background:rgba(20,35,55,0.4);
        border-radius:2px;border:1px solid rgba(106,136,176,0.2);"></div><span>0%</span>
    </div>
    <div style="display:flex;align-items:center;gap:4px;">
      <div style="width:28px;height:13px;background:rgba(80,18,28,0.75);border-radius:2px;"></div><span>15%</span>
    </div>
    <div style="display:flex;align-items:center;gap:4px;">
      <div style="width:28px;height:13px;background:rgba(139,0,0,0.95);border-radius:2px;"></div><span>30%+</span>
    </div>
    <span style="margin-left:4px;">⬛ = no data &nbsp;·&nbsp; gray = &lt;20 items &nbsp;·&nbsp; Click row or cell → adds to lag curve</span>
  </div>`;

  container.innerHTML = html;
}

function ilSelectWeek(weekStr) {
  const sel = document.getElementById('ilWeekSelect');
  if (!sel) return;
  const opt = [...sel.options].find(o => o.value === weekStr);
  if (!opt) return;
  if (!opt.selected) {
    const numSelected = [...sel.selectedOptions].length;
    if (numSelected >= 4) {
      const first = [...sel.selectedOptions][0];
      if (first) first.selected = false;
    }
    opt.selected = true;
  }
  itemLagState.selectedWeeks = [...sel.selectedOptions].map(o => o.value);
  loadItemLagAnalysis();
}

function renderItemLagTable(data) {
  const tbody = document.getElementById('ilTableBody');
  if (!tbody) return;

  const { table } = data;
  if (!table.length) {
    tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:var(--text-muted);padding:20px;">Select a ship week above to see breakdown</td></tr>';
    return;
  }

  const sorted = [...table].sort((a, b) => b.hateRate - a.hateRate);
  tbody.innerHTML = sorted.map(row => {
    const lowVol    = row.total < 20;
    const hateStyle = !lowVol && row.hateRate > 0.18 ? 'color:var(--dark-side)'  :
                      !lowVol && row.hateRate < 0.12 ? 'color:var(--light-side)' : '';
    const newPct = row.newHateRate       != null ? `${(row.newHateRate       * 100).toFixed(1)}%` : '—';
    const recPct = row.recurringHateRate != null ? `${(row.recurringHateRate * 100).toFixed(1)}%` : '—';
    const newN   = row.newTotal > 0 ? ` <span style="color:var(--text-muted);font-size:10px;">(${row.newTotal})</span>` : '';
    const recN   = row.recTotal > 0 ? ` <span style="color:var(--text-muted);font-size:10px;">(${row.recTotal})</span>` : '';
    const daysStr = row.avgDaysToRate != null ? `${row.avgDaysToRate}d` : '—';
    return `<tr${lowVol ? ' class="low-vol-row"' : ''}>
      <td><strong>${formatWeekLabel(row.shipWeek)}</strong></td>
      <td>${lowVol ? '<span class="low-vol">low vol</span>' : row.total.toLocaleString()}</td>
      <td style="${hateStyle};font-weight:600">${(row.hateRate * 100).toFixed(1)}%</td>
      <td style="color:var(--light-side)">${(row.loveRate * 100).toFixed(1)}%</td>
      <td>${daysStr}</td>
      <td>${newPct}${newN}</td>
      <td>${recPct}${recN}</td>
    </tr>`;
  }).join('');
}

function renderItemLagDimBreakdown(data, dim) {
  const section   = document.getElementById('ilDimSection');
  const titleEl   = document.getElementById('ilDimTitle');
  const tablesEl  = document.getElementById('ilDimTables');
  if (!section || !tablesEl) return;

  const { dimensionBreakdown, selectedWeeks, baselineRate } = data;
  const activeDim = dim || state.dimension || 'product_brand';

  // Hide if no breakdown data at all
  if (!dimensionBreakdown || Object.keys(dimensionBreakdown).length === 0) {
    section.style.display = 'none';
    return;
  }

  section.style.display = 'block';
  const dimLabel = getDimensionLabel(activeDim);
  if (titleEl) titleEl.textContent = `📊 ${dimLabel} Breakdown by Ship Week`;

  const multiWeek = selectedWeeks.length > 1;

  // Build combined rows with ship week attached (for multi-week grouping)
  const allRows = [];
  for (const wk of selectedWeeks) {
    const rows = dimensionBreakdown[wk] || [];
    for (const r of rows) allRows.push({ ...r, shipWeek: wk });
  }

  if (!allRows.length) {
    tablesEl.innerHTML = `<div style="color:var(--text-muted);font-size:12px;padding:12px 0;">No dimension data available for selected weeks.</div>`;
    return;
  }

  // Render one unified table; ship week sub-header rows separate weeks when multiple selected
  const baselinePct = ((baselineRate || 0) * 100).toFixed(1);

  let tbody = '';
  let lastWk = null;
  for (const r of allRows) {
    if (multiWeek && r.shipWeek !== lastWk) {
      lastWk = r.shipWeek;
      tbody += `<tr style="background:rgba(255,255,255,0.04);">
        <td colspan="7" style="font-weight:600;font-size:11px;color:var(--text-secondary);
                               padding:8px 12px;letter-spacing:0.05em;text-transform:uppercase;">
          📅 Ship Week: ${formatWeekLabel(r.shipWeek)}
        </td></tr>`;
    }

    const hStyle = r.hateRate > 0.20 ? 'color:var(--dark-side);font-weight:600'
                 : r.hateRate < 0.10 ? 'color:var(--light-side)' : '';
    const liftSign  = r.lift >= 0 ? '+' : '';
    const liftStyle = r.lift > 0.10 ? 'color:var(--dark-side);font-weight:600'
                    : r.lift < -0.10 ? 'color:var(--light-side)' : '';
    const zStyle    = Math.abs(r.zScore) >= 1.96 ? 'font-weight:600' : '';
    const zColor    = r.zScore >= 1.96 ? 'color:var(--dark-side)' : r.zScore <= -1.96 ? 'color:var(--light-side)' : '';
    const sigBadge  = r.significant ? '<span style="font-size:9px;background:rgba(239,68,68,0.15);color:var(--dark-side);border-radius:3px;padding:1px 4px;margin-left:4px;">sig</span>' : '';
    const newPct    = r.newHateRate       != null ? (r.newHateRate       * 100).toFixed(1) + '%' : '—';
    const recPct    = r.recurringHateRate != null ? (r.recurringHateRate * 100).toFixed(1) + '%' : '—';

    tbody += `<tr>
      <td>${escapeHtml(r.value)}</td>
      ${multiWeek ? '' : `<td>${formatWeekLabel(r.shipWeek)}</td>`}
      <td>${r.total.toLocaleString()}</td>
      <td style="${hStyle}">${(r.hateRate * 100).toFixed(1)}%</td>
      <td style="${liftStyle}">${liftSign}${(r.lift * 100).toFixed(1)}%</td>
      <td style="${zStyle};${zColor}">${r.zScore.toFixed(2)}${sigBadge}</td>
      <td>${newPct}</td>
      <td>${recPct}</td>
    </tr>`;
  }

  // Show "Ship Week" column only when single week selected (otherwise sub-headers used)
  const weekCol = multiWeek ? '' : '<th>Ship Week</th>';

  tablesEl.innerHTML = `
    <div style="font-size:11px;color:var(--text-muted);margin-bottom:8px;">
      Overall baseline hate rate: <strong style="color:var(--text-primary);">${baselinePct}%</strong>
    </div>
    <table class="driver-table">
      <thead><tr>
        <th>${dimLabel}</th>
        ${weekCol}
        <th title="Total items rated for this dimension value in this ship week">Items</th>
        <th title="% of items rated 1 or 2 stars">Hate Rate</th>
        <th title="How much higher or lower vs the overall average">Lift vs Avg</th>
        <th title="Statistical significance: |Z| ≥ 1.96 = significant (marked 'sig')">Z-Score</th>
        <th title="Hate rate for first-box (new) customers">New Hate Rate</th>
        <th title="Hate rate for returning customers">Rec Hate Rate</th>
      </tr></thead>
      <tbody>${tbody}</tbody>
    </table>`;
}

