async function loadActionSignals() {
  const { start, end } = getReportDateRange();
  const params = new URLSearchParams({ ratingType: state.ratingType });
  if (start) params.set('start', start);
  if (end)   params.set('end',   end);
  try {
    const res = await fetch(`${API_BASE}/action-signals?${params}`);
    if (!res.ok) return;
    const data = await res.json();
    renderActionSignals(data);
  } catch (e) {
    console.error('Action signals failed:', e.message);
  }
}

function renderActionSignals({ signals, baselineRate }) {
  const listEl  = document.getElementById('actionSignalsList');
