// --- Report Generation ---
document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('generateReport').addEventListener('click', generateReport);
});

async function generateReport() {
  const btn = document.getElementById('generateReport');
  const status = document.getElementById('reportStatus');
  const content = document.getElementById('reportContent');

  btn.disabled = true;
  status.innerHTML = '<span class="loading-spinner"></span> Compiling intelligence briefing...';

  try {
    // Use report-specific date range, not item health date range
    const { start, end } = getReportDateRange();
    const params = new URLSearchParams({ ratingType: state.ratingType });
    if (start) params.set('start', start);
    if (end)   params.set('end',   end);

    // Fetch report, weekly breakdown, and action signals in parallel
    const [reportRes, weeklyRes] = await Promise.all([
      fetch(`${API_BASE}/report?${params}`),
      fetch(`${API_BASE}/weekly-report?${params}`)
    ]);
    const report = await reportRes.json();
    const weekly = weeklyRes.ok ? await weeklyRes.json() : null;

    content.innerHTML = renderReport(report, start, end, weekly);

    // Action signals loads independently — updates its own panel
    loadActionSignals();

    status.textContent = 'Briefing complete.';
  } catch (err) {
    status.textContent = 'Failed to generate report.';
    console.error(err);
  }

  btn.disabled = false;
}

function renderReport(report, start, end, weekly) {
  const rate = (report.baseline.rate * 100).toFixed(1);
  const hateCount = report.baseline.hateCount;
  const total = report.baseline.total;
  const boxCount = weekly?.boxCount ?? null;

  // Threat level
  let threatLabel;
  if (report.baseline.rate < 0.10) threatLabel = '🟢 LOW — The Force is with us';
  else if (report.baseline.rate < 0.15) threatLabel = '🟡 ELEVATED — Stay vigilant';
  else if (report.baseline.rate < 0.20) threatLabel = '🟠 HIGH — Dark Side activity detected';
  else threatLabel = '🔴 CRITICAL — The Dark Side is strong';

  // Top drivers
  const topBad = report.topDrivers.filter(d => d.lift > 0 && d.significant).slice(0, 8);
  const topGood = report.topDrivers.filter(d => d.lift < 0 && d.significant).slice(0, 5);

  // Stylist outliers
  const stylistOutliers = report.stylistVariance
    .filter(s => s.direction === 'above' && s.significant)
    .sort((a, b) => b.lift - a.lift)
    .slice(0, 5);

  const periodLabel = start && end ? `${start} → ${end}` : start ? `From ${start}` : 'All Time';
  const boxCountStr = boxCount != null ? ` &nbsp;·&nbsp; <strong>${boxCount.toLocaleString()}</strong> boxes rated` : '';

  let html = `<div class="report-body">
    <h2>⚔️ Hate It Rate Intel Briefing</h2>
    <p style="color:var(--text-muted);">Period: ${periodLabel} | Generated: ${new Date().toLocaleString()}</p>

    <h3>📊 Top-Line Summary</h3>
    <p><strong>What you need to know:</strong> This section gives you the big picture — is customer dissatisfaction going up, down, or staying flat?</p>
    <p>Overall Hate It Rate: <span class="metric-highlight">${rate}%</span>
    &nbsp;(${hateCount.toLocaleString()} hate ratings out of ${total.toLocaleString()} rated items${boxCountStr})</p>
    <p>Threat Level: <strong>${threatLabel}</strong></p>
    <p><strong>In plain English:</strong> Out of every 100 items customers rated, about ${Math.round(report.baseline.rate * 100)} were rated as "Hate It" (1 or 2 stars).
    ${report.baseline.rate > 0.15 ? 'This is above our target — we need to take action.' : 'This is within an acceptable range, but we should watch the drivers below.'}</p>`;

  // --- Weekly breakdown table ---
  if (weekly && weekly.weeklyDrivers && weekly.weeklyDrivers.length > 0) {
    html += `<h3>📅 Weekly Breakdown — Ranked by Impact</h3>
    <p><strong>What you need to know:</strong> Each week's hate rate and the single biggest driver pulling it up. Weeks are ordered newest first.</p>
    <table class="driver-table" style="margin-bottom:8px;">
      <thead><tr>
        <th>Week</th>
        <th title="% of items rated 1-2 stars">Hate Rate</th>
        <th>Items Rated</th>
        <th>Hate Count</th>
        <th title="Top single driver by statistical confidence for this week">Primary Driver</th>
      </tr></thead>
      <tbody>`;

    for (const wk of weekly.weeklyDrivers) {
      const hStyle  = wk.hateRate > 0.18 ? 'color:var(--dark-side);font-weight:600' :
                      wk.hateRate < 0.12 ? 'color:var(--light-side)' : '';
      const lowVol  = wk.total < 30;
      let primaryDriver = '—';
      if (wk.topDriver) {
        const d = wk.topDriver;
        const dimLabel = getDimensionLabel(d.dimension);
        const liftPct  = (d.lift * 100).toFixed(0);
        primaryDriver  = `<strong>${escapeHtml(dimLabel)}: ${escapeHtml(d.value)}</strong>
          &nbsp;<span class="lift-positive">+${liftPct}%</span>
          <span style="color:var(--text-muted);font-size:10px;">(${d.total} items, z=${d.zScore.toFixed(1)})</span>`;
      }
      html += `<tr${lowVol ? ' class="low-vol-row"' : ''}>
        <td><strong>${formatWeekLabel(wk.week)}</strong></td>
        <td style="${hStyle}">${lowVol ? '<span class="low-vol">low vol</span>' : (wk.hateRate*100).toFixed(1)+'%'}</td>
        <td>${wk.total.toLocaleString()}</td>
        <td>${wk.hateCount}</td>
        <td style="font-size:12px;">${primaryDriver}</td>
      </tr>`;
    }
    html += '</tbody></table>';
    html += `<p style="font-size:11px;color:var(--text-muted);">Weeks with fewer than 30 rated items are marked "low vol" — treat these as early signal only.</p>`;
  }

  html += `<h3>🎯 Key Drivers — What's Causing Negative Feedback</h3>
    <p><strong>What you need to know:</strong> These are the specific brands, categories, stylists, etc. that are driving the most negative feedback.
    Items at the top are our biggest problems. "Lift" tells you how much worse something is compared to our average.</p>`;

  if (topBad.length > 0) {
    html += '<ul>';
    for (const d of topBad) {
      const dimLabel = getDimensionLabel(d.dimension);
      const liftPct = (d.lift * 100).toFixed(0);
      const dRate = (d.hateRate * 100).toFixed(1);
      const action = getRecommendedAction(d.dimension, d.value, d.lift);
      html += `<li><strong>${dimLabel}: ${escapeHtml(d.value)}</strong> — Hate It Rate: <span class="metric-highlight">${dRate}%</span> (${liftPct}% above baseline, ${d.total} items)
        <br><em>→ Recommended action: ${action}</em></li>`;
    }
    html += '</ul>';
  } else {
    html += '<p>No statistically significant negative drivers found for this period. 🎉</p>';
  }

  if (topGood.length > 0) {
    html += `<h3>🌟 Bright Spots — What's Working Well</h3>
    <p><strong>What you need to know:</strong> These are performing better than average. Consider giving them more allocation.</p><ul>`;
    for (const d of topGood) {
      const dimLabel = getDimensionLabel(d.dimension);
      const liftPct = Math.abs(d.lift * 100).toFixed(0);
      html += `<li><strong>${dimLabel}: ${escapeHtml(d.value)}</strong> — <span class="metric-good">${liftPct}% below baseline</span> (${d.total} items)</li>`;
    }
    html += '</ul>';
  }

  if (stylistOutliers.length > 0) {
    html += `<h3>👤 Stylist Variance</h3>
    <p><strong>What you need to know:</strong> These stylists have significantly higher hate-it rates than average.
    This could mean they need coaching, or they might be assigned harder-to-style customers. Worth investigating.</p><ul>`;
    for (const s of stylistOutliers) {
      const liftPct = (s.lift * 100).toFixed(0);
      html += `<li><strong>${escapeHtml(s.value)}</strong> — Hate It Rate: <span class="metric-highlight">${(s.hateRate * 100).toFixed(1)}%</span> (+${liftPct}% vs avg, ${s.total} items)</li>`;
    }
    html += '</ul>';
  }

  // Early warning
  if (report.earlyWarning && report.earlyWarning.length > 0) {
    const alerts = report.earlyWarning.filter(c => c.isEarlyWarning);
    if (alerts.length > 0) {
      html += `<h3>🚨 Early Warning Flags</h3>
      <p><strong>What you need to know:</strong> These are recent shipments where early feedback suggests problems.
      Not all ratings are in yet, so these could change — but they're worth watching closely.</p><ul>`;
      for (const a of alerts) {
        html += `<li><strong>${formatWeekLabel(a.weekOf)}</strong>: ${a.shipped} items shipped, only ${(a.completionRate * 100).toFixed(0)}% rated so far, running at <span class="metric-highlight">${(a.hateRate * 100).toFixed(1)}% hate rate</span></li>`;
      }
      html += '</ul>';
    }
  }

  html += `<h3>📋 Recommended Next Steps</h3>
  <p><strong>What you need to know:</strong> Based on the data above, here are concrete actions we can take.</p><ol>`;

  // Generate contextual actions
  if (topBad.length > 0) {
    const brandIssues = topBad.filter(d => d.dimension === 'product_brand');
    const stylistIssues = topBad.filter(d => d.dimension === 'Stylist');
    const catIssues = topBad.filter(d => d.dimension === 'product_category');

    if (brandIssues.length > 0) {
      html += `<li><strong>Merch Review:</strong> ${brandIssues.map(b => escapeHtml(b.value)).join(', ')} — flag for allocation reduction or replacement</li>`;
    }
    if (stylistIssues.length > 0) {
      html += `<li><strong>Stylist QA:</strong> Review recent picks from ${stylistIssues.map(s => escapeHtml(s.value)).join(', ')}</li>`;
    }
    if (catIssues.length > 0) {
      html += `<li><strong>Category Mix:</strong> Review ${catIssues.map(c => escapeHtml(c.value)).join(', ')} category mix and sourcing quality</li>`;
    }
  }
  html += `<li><strong>Monitor:</strong> Re-run this report in 7 days to track improvement</li>`;
  html += '</ol>';

  html += `<div class="report-timestamp">Generated by Hate It Rate Command Center | ${new Date().toISOString()}</div>`;
  html += '</div>';
  return html;
}

function getRecommendedAction(dimension, value, lift) {
  const actions = {
    'product_brand': `Flag ${value} for merch review — consider reducing allocation or investigating quality issues`,
    'product_category': `Review ${value} category mix — check if specific subcategories or brands are driving the issue`,
    'product_subcategory': `Investigate ${value} quality and fit — may need to adjust sourcing`,
    'Stylist': `QA recent picks from ${value} — coaching or workload adjustment may be needed`,
    'plan': `Review curation strategy for ${value} tier — expectations may not match delivery`,
    'customerType': value === 'New Customer' ? `Review first-box curation — new customers are churning at high rates` : `Investigate recurring customer fatigue — review refresh strategy`,
    'BoxNumber': lift > 0.3 ? `Critical: Box ${value} retention risk — review onboarding curation` : `Monitor Box ${value} experience`,
    'product_sourcing': `Investigate ${value} supplier quality — may need new sourcing partners`,
    'ShipAddrState': `Check regional trends for ${value} — seasonal or demographic mismatch possible`,
    'product_color_style': `Review ${value} selections — may not match customer preferences`,
    'product_seasonality': `Check ${value} seasonal relevance — may be out of season`,
    'DayStyle': `Review curation for ${value} style preference — may need better matching`,
    'EveningStyle': `Check evening style alignment for ${value} customers`,
    'BottomFit': `Review fit recommendations for ${value} — sizing guidance may need updating`,
    'TopSize': `Check size ${value} availability and fit consistency across brands`,
    'WaistSize': `Review waist ${value} fit — check if specific brands run differently at this size`,
    'Value': `Customers rating value as "${value}" — ${lift > 0 ? 'review price-to-quality ratio' : 'keep doing what works'}`,
    'Presentation': `Presentation rated "${value}" — ${lift > 0 ? 'review packaging and unboxing experience' : 'maintain current standards'}`,
    'ShopAt': `${value} shoppers have different expectations — review brand mix for this segment`
  };
  return actions[dimension] || 'Investigate further';
}

