// Wire the sentiment / customer-type toggles above BH charts
function setupBHToggles() {
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('[data-bh-toggle]');
    if (!btn) return;
    const group = btn.dataset.bhToggle;
    const val   = btn.dataset.val;
    // Deactivate siblings in same toggle group
    btn.closest('.toggle-group').querySelectorAll('.toggle-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    if (!bhState.charts) return; // safety
    if (group === 'style') {
      bhState.styleSentiment = val;
      if (bhState.lastData) renderBHStyleChart(bhState.lastData.styleAccuracy, val);
    } else if (group === 'value') {
      bhState.valueSentiment = val;
      if (bhState.lastData) renderBHValueChart(bhState.lastData.valuePerception, val);
    } else if (group === 'dist') {
      bhState.distCustomerType = val;
      if (bhState.lastData) renderBHDistChart(bhState.lastData.boxTrend, val);
    }
  });

  // Box Health date range buttons
  document.querySelectorAll('.bh-range-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.bh-range-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const customPanel = document.getElementById('bhCustomRange');
      if (btn.dataset.days === 'custom') {
        // Show date pickers, don't re-render until both dates chosen
        bhState.bhDateDays = -1;
        if (customPanel) { customPanel.style.display = 'flex'; customPanel.classList.remove('hidden'); }
      } else {
        bhState.bhDateDays = parseInt(btn.dataset.days) || 0;
        bhState.bhCustomStart = null;
        bhState.bhCustomEnd   = null;
        if (customPanel) { customPanel.style.display = 'none'; customPanel.classList.add('hidden'); }
        if (bhState.lastData) { renderBoxHealthAll(bhState.lastData); loadCustomerProfiles(bhState.lastData); }
      }
    });
  });

  // Custom date inputs for Box Health
  document.getElementById('bhCustomStart')?.addEventListener('change', (e) => {
    bhState.bhCustomStart = e.target.value || null;
    if (bhState.bhCustomStart && bhState.bhCustomEnd && bhState.lastData) { renderBoxHealthAll(bhState.lastData); loadCustomerProfiles(bhState.lastData); }
  });
  document.getElementById('bhCustomEnd')?.addEventListener('change', (e) => {
    bhState.bhCustomEnd = e.target.value || null;
    if (bhState.bhCustomStart && bhState.bhCustomEnd && bhState.lastData) { renderBoxHealthAll(bhState.lastData); loadCustomerProfiles(bhState.lastData); }
