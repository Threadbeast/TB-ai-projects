// --- Early Warning ---
function showEarlyWarning(data) {
  const section = document.getElementById('earlyWarningSection');
  section.style.display = 'block';

  const tbody = document.getElementById('earlyWarningBody');
  tbody.innerHTML = data.cohorts.map(c => {
    let statusBadge;
    if (c.completionRate < 0.3 && c.hateRate > 0.18) {
      statusBadge = '<span class="status-badge status-badge--danger">🔴 HIGH ALERT</span>';
    } else if (c.isEarlyWarning) {
      statusBadge = '<span class="status-badge status-badge--alert">🟠 Watch</span>';
    } else {
      statusBadge = '<span class="status-badge status-badge--ok">🟢 Normal</span>';
    }

    const lowVol = c.rated < 30;
    const rateCell = lowVol
      ? `<span class="low-vol" title="Fewer than 30 ratings — not reliable yet">low vol</span>`
      : `<span class="${c.hateRate > 0.15 ? 'lift-positive' : ''}">${(c.hateRate * 100).toFixed(1)}%</span>`;

    return `<tr${lowVol ? ' class="low-vol-row"' : ''}>
      <td>${formatWeekLabel(c.weekOf)}</td>
      <td>${c.shipped.toLocaleString()}</td>
      <td>${c.rated.toLocaleString()}</td>
      <td>${(c.completionRate * 100).toFixed(0)}%</td>
      <td>${rateCell}</td>
      <td>${statusBadge}</td>
    </tr>`;
  }).join('');

  // Add explainer
  removeExplainer(section);
  section.insertAdjacentHTML('beforeend', EXPLAINERS.earlyWarning);
}

// --- Enrichment Panel ---
function showEnrichment(driver) {
  const panel = document.getElementById('enrichmentPanel');
  panel.style.display = 'block';
  document.getElementById('enrichmentTarget').textContent = driver.value;

  const enrich = driver.enrichment;

  // Sentiment breakdown bar (all-rated style accuracy)
  renderSentimentBreakdown(enrich);

  // Style accuracy bars (hate items only — backward compat)
  renderEnrichmentBars('enrichStyleAccuracy', enrich.styleAccuracy, {
    'Not me': 'var(--dark-side)',
    'Mostly me': 'var(--neutral)',
    'Love it': 'var(--light-side)'
  });

  // Quality bars
  renderEnrichmentBars('enrichQuality', enrich.quality, {
    'Poor': 'var(--dark-side)',
    'Good': 'var(--neutral)',
    'Excellent': 'var(--light-side)'
  });

  // Fit bars
  renderEnrichmentBars('enrichFit', enrich.fit, {
    'Too small': 'var(--dark-side)',
    'Too large': 'var(--dark-side)',
    'Slightly small': 'var(--neutral)',
    'Slightly large': 'var(--neutral)',
    'Perfect': 'var(--light-side)'
  });

  // Comments — use commentsWithDates if available, fall back to sampleComments
  const commentsEl = document.getElementById('enrichComments');
  const withDates  = enrich.commentsWithDates || [];
  const plain      = enrich.sampleComments    || [];

  if (withDates.length > 0) {
    commentsEl.innerHTML = withDates.map(c => {
      const weekLabel = c.week ? `<span style="color:var(--text-muted);font-size:10px;margin-right:6px;">${formatWeekLabel(c.week)}</span>` : '';
      return `<div class="comment-item">${weekLabel}"${escapeHtml(c.text)}"</div>`;
    }).join('');
  } else if (plain.length > 0) {
    commentsEl.innerHTML = plain
      .map(c => `<div class="comment-item">"${escapeHtml(c)}"</div>`).join('');
  } else {
    commentsEl.innerHTML = '<p style="color:var(--text-muted);font-size:12px;">No comments available for hate-rated items in this group.</p>';
  }

  // Add explainer
  removeExplainer(panel);
  panel.insertAdjacentHTML('beforeend', EXPLAINERS.enrichment);
}

function renderEnrichmentBars(elId, data, colorMap) {
  const el = document.getElementById(elId);
  const total = Object.values(data).reduce((a, b) => a + b, 0);
  if (total === 0) {
    el.innerHTML = '<p style="color:var(--text-muted);font-size:12px;">No data</p>';
    return;
  }

  el.innerHTML = Object.entries(data)
    .sort((a, b) => b[1] - a[1])
    .map(([label, count]) => {
      const pct = (count / total * 100).toFixed(0);
      const color = colorMap[label] || 'var(--accent)';
      return `<div class="enrichment-bar">
        <span class="enrichment-bar__label">${escapeHtml(label)}</span>
        <div class="enrichment-bar__track">
          <div class="enrichment-bar__fill" style="width:${pct}%;background:${color}"></div>
        </div>
        <span class="enrichment-bar__value">${pct}%</span>
      </div>`;
    }).join('');
}

