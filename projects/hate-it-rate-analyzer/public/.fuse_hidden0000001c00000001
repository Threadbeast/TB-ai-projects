// --- Chart 5: Rating Distribution (100% stacked bar) ---
function renderBHDistChart(boxTrend, customerType) {
  const ctx = document.getElementById('bhDistChart').getContext('2d');
  if (bhState.charts.dist) bhState.charts.dist.destroy();

  // Combine new + recurring into one weighted bar per week
  const weeksSet = new Set(boxTrend.map(r => r.week_start));
  const weeks    = [...weeksSet].sort();
  const lookup   = {};
  for (const r of boxTrend) {
    if (!lookup[r.week_start]) lookup[r.week_start] = { hate: 0, neutral: 0, love: 0, total: 0 };
    lookup[r.week_start].hate    += r.hate    || 0;
    lookup[r.week_start].neutral += r.neutral || 0;
    lookup[r.week_start].love    += r.love    || 0;
    lookup[r.week_start].total   += r.total   || 0;
  }

  const pct = (w, field) => {
    const row = lookup[w];
    return (row && row.total > 0) ? +(row[field] / row.total * 100).toFixed(1) : null;
  };

  bhState.charts.dist = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: weeks.map(w => formatWeekLabel(w)),
      datasets: [
        { label: 'Hate (1–2)', stack: 'dist', data: weeks.map(w => pct(w,'hate')),    backgroundColor: 'rgba(255,45,45,0.8)',    borderWidth: 0 },
        { label: 'Neutral (3)', stack: 'dist', data: weeks.map(w => pct(w,'neutral')), backgroundColor: 'rgba(100,120,150,0.5)',  borderWidth: 0 },
        { label: 'Love (4–5)', stack: 'dist', data: weeks.map(w => pct(w,'love')),    backgroundColor: 'rgba(0,230,118,0.75)',   borderWidth: 0 },
      ]
    },
    options: {
      ...BH_CHART_DEFAULTS,
      scales: {
        x: { stacked: true, ticks: { color: '#6a88b0', font: { size: 10 }, maxRotation: 45, maxTicksLimit: 18 }, grid: { display: false } },
        y: { stacked: true, beginAtZero: true, max: 100, ticks: { callback: v => v + '%', color: '#6a88b0', font: { size: 11 } }, grid: { color: 'rgba(0,180,255,0.06)' } }
      },
      plugins: { ...BH_CHART_DEFAULTS.plugins, tooltip: { callbacks: {
        title: items => items.length ? formatWeekLabel(weeks[items[0].dataIndex]) : '',
        label: ctx => ctx.parsed.y != null ? `${ctx.dataset.label}: ${ctx.parsed.y.toFixed(1)}%` : null,
        afterBody: items => {
          const w = weeks[items[0]?.dataIndex];
          return w && lookup[w] ? [`${lookup[w].total.toLocaleString()} total boxes rated`] : [];
        }
      }}}
    }
  });

  const container = document.getElementById('bhDistChart').closest('.chart-container');
  removeExplainer(container);
  container.insertAdjacentHTML('beforeend', `<div class="explainer">
    <strong>What this shows:</strong> How box ratings break down each week — Hate (1–2), Neutral (3), and Love (4–5) stacked to 100%.
    New and recurring customers are combined. Hover any bar to see exact percentages and total boxes rated.
    <br><br>
    <strong>Key insight:</strong> Watch for the red segment growing or the green segment shrinking week-over-week.
    A healthy box program has a dominant green band with a thin, stable red sliver at the bottom.
  </div>`);
}

// --- Box Health Driver Table ---
function renderBHDriverTable(boxDrivers, dimension) {
  const tbody = document.getElementById('bhDriverTableBody');
  if (!tbody) return;

  const rows = (boxDrivers || {})[dimension] || [];
  if (!rows.length) {
    tbody.innerHTML = `<tr><td colspan="6" style="text-align:center;color:#6a88b0;padding:20px;">No data yet — drivers load on next cache refresh</td></tr>`;
    return;
  }

  // Compute overall avg hate rate
  const totalHate = rows.reduce((s,r) => s + r.hate, 0);
  const totalAll  = rows.reduce((s,r) => s + r.total, 0);
  const avgHate   = totalAll > 0 ? totalHate / totalAll : 0;

  tbody.innerHTML = rows.slice(0, 25).map((r, i) => {
    const hateClass = r.hate_rate > avgHate * 1.5 ? 'color:var(--dark-side)' :
                      r.hate_rate < avgHate * 0.7 ? 'color:var(--light-side)' : '';
    const liftStr = r.lift > 0
      ? `<span style="color:var(--dark-side)">▲ ${(r.lift * 100).toFixed(0)}%</span>`
      : `<span style="color:var(--light-side)">▼ ${Math.abs(r.lift * 100).toFixed(0)}%</span>`;
    const val = dimension === 'package_num'
      ? (r.dim_value === '1' ? '1st Box (New)' : `Box #${r.dim_value}`)
      : escapeHtml(String(r.dim_value));
    return `<tr>
      <td>${i + 1}</td>
      <td>${val}</td>
      <td style="${hateClass};font-weight:600">${(r.hate_rate * 100).toFixed(1)}%</td>
      <td>${(r.love_rate * 100).toFixed(1)}%</td>
      <td>${r.total.toLocaleString()}</td>
      <td>${liftStr}</td>
    </tr>`;
  }).join('');
}

