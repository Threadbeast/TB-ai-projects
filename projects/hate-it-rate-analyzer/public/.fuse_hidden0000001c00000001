// --- Cache status ---
async function loadCacheStatus() {
  try {
    const res = await fetch(`${API_BASE}/cache/status');
    const info = await res.json();
    const el = document.getElementById('cacheInfo');
    if (!el) return;
    if (!info.exists) {
      el.textContent = 'LIVE / BQ';
      el.className = 'cache-info cache-live';
    } else if (info.stale) {
      el.textContent = `CACHE STALE (${info.ageMinutes}m)`;
      el.className = 'cache-info cache-stale';
    } else {
      const h = Math.floor(info.ageMinutes / 60);
      const m = info.ageMinutes % 60;
      const age = h > 0 ? `${h}h ${m}m` : `${m}m`;
      el.textContent = `CACHE ${age} OLD · ${info.sizeMB}MB`;
      el.className = 'cache-info cache-fresh';
    }
  } catch (e) { /* silent */ }
}

// --- Force Refresh button ---
function setupForceRefresh() {
  const btn = document.getElementById('forceRefresh');
  if (!btn) return;
  btn.addEventListener('click', async () => {
    if (btn.disabled) return;
    btn.disabled = true;
    btn.classList.add('refreshing');
    btn.textContent = '↺ Clearing cache...';

    try {
      await fetch(`${API_BASE}/cache/clear', { method: 'POST' });
      btn.textContent = '↺ Fetching from BQ...';

      // Poll until data is ready (server reloads in background)
      let attempts = 0;
      const poll = setInterval(async () => {
        attempts++;
        try {
          const res = await fetch(`${API_BASE}/summary');
          const data = await res.json();
          if (data.totalRated > 0) {
            clearInterval(poll);
            btn.disabled = false;
            btn.classList.remove('refreshing');
            btn.textContent = '↺ Force Refresh';
            loadDashboard();
            loadCacheStatus();
          } else if (attempts > 60) {
            clearInterval(poll);
            btn.disabled = false;
            btn.classList.remove('refreshing');
            btn.textContent = '↺ Force Refresh';
          }
        } catch (e) { /* keep polling */ }
      }, 3000);
    } catch (e) {
      btn.disabled = false;
      btn.classList.remove('refreshing');
      btn.textContent = '↺ Force Refresh';
    }
  });
}

async function loadDimensions() {
  let attempts = 0;
  while (attempts < 10) {
    try {
      const res = await fetch(`${API_BASE}/dimensions');
      const data = await res.json();
      const select = document.getElementById('dimensionSelect');
      // Always lead with Overall option
      select.innerHTML = '<option value="">Overall</option>';
      for (const dim of data.dimensions) {
        const opt = document.createElement('option');
        opt.value = dim;
        opt.textContent = getDimensionLabel(dim);
        select.appendChild(opt);
      }
      // Keep current dimension if valid; otherwise default to Overall
      const validDims = ['', ...data.dimensions];
      if (!validDims.includes(state.dimension)) {
        state.dimension = '';
      }
      select.value = state.dimension;
      return;
    } catch (e) {
      attempts++;
      await new Promise(r => setTimeout(r, 2000));
    }
  }
}

// Route date-range triggered reloads to whichever tab is active
function triggerReload() {
  if (state.activeLayer === 'box-health') loadBoxHealth();
  else if (state.activeLayer === 'item-health') loadDashboard();
  // report / chat don't reload on date change
}

// --- Controls ---
function setupControls() {
  document.getElementById('dateRange').addEventListener('change', (e) => {
    const val = e.target.value;
    if (val === 'custom') {
      document.getElementById('customStart').classList.remove('hidden');
      document.getElementById('customEnd').classList.remove('hidden');
    } else {
      document.getElementById('customStart').classList.add('hidden');
      document.getElementById('customEnd').classList.add('hidden');
      state.dateRange = parseInt(val);
      state.customStart = null;
      state.customEnd = null;
      state.drillStack = [];
      triggerReload();
    }
  });

  document.getElementById('customStart').addEventListener('change', (e) => {
    const snapped = snapToWeekBoundary(e.target.value, 'start');
    e.target.value = snapped;
    state.customStart = snapped;
    if (state.customEnd) triggerReload();
  });

  document.getElementById('customEnd').addEventListener('change', (e) => {
    const snapped = snapToWeekBoundary(e.target.value, 'end');
    e.target.value = snapped;
    state.customEnd = snapped;
    if (state.customStart) triggerReload();
  });

  // Rating type toggle
  document.querySelectorAll('[data-rating]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('[data-rating]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      state.ratingType = btn.dataset.rating;
      loadDashboard();
    });
  });

  // Time view toggle
  document.querySelectorAll('[data-view]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('[data-view]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      state.timeView = btn.dataset.view;
      loadDashboard();
    });
  });

  // Dimension select
  document.getElementById('dimensionSelect').addEventListener('change', (e) => {
    state.dimension = e.target.value;
    state.drillStack = [];
    loadDashboard();
    // Keep lag breakdown in sync if already loaded
    if (itemLagState.loaded) {
      updateILDimLabel(state.dimension || 'product_brand');
      loadItemLagAnalysis();
    }
  });
}

// --- Layer Navigation ---
function setupLayerNav() {
  // Main tabs
  document.querySelectorAll('.layer-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.layer-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      document.querySelectorAll('.layer').forEach(l => l.classList.add('hidden'));
      document.getElementById(`layer-${btn.dataset.layer}`).classList.remove('hidden');

      // Track active layer and lazy-load on first switch
      state.activeLayer = btn.dataset.layer;
      if (state.activeLayer === 'box-health')  loadBoxHealth();
      if (state.activeLayer === 'item-health') loadDashboard();
      if (state.activeLayer === 'report')      loadActionSignals();
    });
  });

  // Sub-tabs — scoped to their parent .layer so Box Health and Item Health don't interfere
  document.querySelectorAll('.sub-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      // Deactivate siblings only within the same sub-nav
      const siblingBtns = btn.closest('.sub-nav').querySelectorAll('.sub-btn');
      siblingBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      // Hide all sub-panels within the same parent layer, show the target one
      const parentLayer = btn.closest('.layer');
      parentLayer.querySelectorAll('.sub-panel').forEach(p => p.classList.add('hidden'));
      document.getElementById(`sub-${btn.dataset.sub}`).classList.remove('hidden');

      // Lazy-load Lag Analysis on first activation
      if (btn.dataset.sub === 'box-lag'  && !lagState.loaded)     loadLagAnalysis();
      if (btn.dataset.sub === 'item-lag' && !itemLagState.loaded)  loadItemLagAnalysis();
    });
  });
}

// --- Date range helpers ---
function getDateRange() {
  if (state.customStart && state.customEnd) {
    return { start: state.customStart, end: state.customEnd };
  }
  const end = new Date();
  const start = new Date(end.getTime() - state.dateRange * 86400000);
  return {
    start: start.toISOString().split('T')[0],
    end: end.toISOString().split('T')[0]
  };
}

// --- Load Dashboard ---
async function loadDashboard() {
  const { start, end } = getDateRange();
  const params = new URLSearchParams({
    start, end,
    ratingType: state.ratingType,
    timeView: state.timeView
  });

  // Determine if we're drilling
  let drillValue = null;
  let dimension = state.dimension;
  if (state.drillStack.length > 0) {
    const last = state.drillStack[state.drillStack.length - 1];
    drillValue = last.value;
    dimension = last.subDimension || state.dimension;
    params.set('drillValue', drillValue);
    params.set('dimension', last.dimension);
  }

  const isOverall = !dimension && state.drillStack.length === 0;

  try {
    // Always fetch summary, trend, baselines; skip drivers fetch in Overall mode
    const fetches = [
      fetch(`${API_BASE}/summary?${params}`),
      isOverall ? Promise.resolve(null) : fetch(`${API_BASE}/drivers?${params}&dimension=${dimension}`),
      fetch(`${API_BASE}/trend?start=${start}&end=${end}&ratingType=${state.ratingType}`),
      fetch(`${API_BASE}/baselines?start=${start}&end=${end}&ratingType=${state.ratingType}`)
    ];
    const [summaryRes, driversRes, trendRes, baselinesRes] = await Promise.all(fetches);

    const summary   = await summaryRes.json();
    const drivers   = driversRes ? await driversRes.json() : null;
    const trendData = trendRes.ok ? await trendRes.json() : null;
    const baselines = baselinesRes.ok ? await baselinesRes.json() : null;

    updateSummaryCards(summary, baselines);
    updateTrendChart(trendData ? trendData.trend : summary.weeklyTrend, baselines);
    updateDistChart(summary.baseline);
    updateDrillPath();
    updateDataStatus(summary.totalRated);

    if (isOverall) {
      // Overall mode — hide driver table and enrichment, keep heatmap + charts
      const driverSection = document.getElementById('itemDriverSection');
      if (driverSection) driverSection.style.display = 'none';
      document.getElementById('enrichmentPanel').style.display = 'none';
      document.getElementById('drillPath').innerHTML = '';
    } else {
      const driverSection = document.getElementById('itemDriverSection');
      if (driverSection) driverSection.style.display = '';
      updateDriverTable(drivers, dimension);
    }

    loadBrandCategoryHeatmap();

    // Show early warning if shipped cohort view
    if (state.timeView === 'shipped') {
      const ewRes = await fetch(`${API_BASE}/early-warning?ratingType=${state.ratingType}`);
      const ew = await ewRes.json();
      showEarlyWarning(ew);
    } else {
      document.getElementById('earlyWarningSection').style.display = 'none';
    }

  } catch (err) {
    console.error('Failed to load dashboard:', err);
    document.getElementById('dataStatus').textContent = 'Connection lost...';
  }
}

// --- Update Summary Cards ---
// baselines = { prior_period, year_ago, rolling_12mo, rolling_30d } from /api/baselines
function updateSummaryCards(summary, baselines) {
  const rate = summary.baseline.rate;
  const hateCount = summary.baseline.hateCount;
  const total = summary.baseline.total;
  const loveRate = summary.baseline.loveCount / total;

  document.getElementById('hateRate').textContent = (rate * 100).toFixed(1) + '%';
  document.getElementById('totalRated').textContent = total.toLocaleString();
  // Label changes based on rating type: items vs boxes (deduped by package)
  const isBox = state.ratingType === 'box';
  const volumeLabel = document.querySelector('.card--volume .card__label');
  if (volumeLabel) volumeLabel.textContent = isBox ? 'Boxes Rated' : 'Items Rated';
  document.getElementById('hateCount').textContent = `${hateCount.toLocaleString()} hate ${isBox ? 'box' : 'item'} ratings`;
  document.getElementById('loveRate').textContent = (loveRate * 100).toFixed(1) + '%';

  // Delta badges from BQ baselines — hate rate card
  const deltaEl = document.getElementById('hateRateDeltas');
  if (deltaEl && baselines) {
    deltaEl.innerHTML = [
      baselines.prior_period ? formatDeltaBQ(rate, baselines.prior_period, 'prior period') : null,
      baselines.rolling_30d  ? formatDeltaBQ(rate, baselines.rolling_30d,  '30d avg')      : null,
      baselines.rolling_12mo ? formatDeltaBQ(rate, baselines.rolling_12mo, '12mo avg')     : null,
      baselines.year_ago && baselines.year_ago.total >= 20
        ? formatDeltaBQ(rate, baselines.year_ago, 'year ago') : null
    ].filter(Boolean).join('');
  }

  // Delta badges — love rate card
  // Convert hate-rate baselines to love-rate equivalents using current love/nonhate ratio
  const loveOfNonHate = summary.baseline.total > 0
    ? summary.baseline.loveCount / (summary.baseline.total - summary.baseline.hateCount || 1)
    : 0.85;
  const loveDeltaEl = document.getElementById('loveRateDeltas');
  if (loveDeltaEl && baselines) {
    // Build love-rate-equivalent refs from hate baselines
    const toLoveRef = (ref) => {
      if (!ref || ref.total < 20) return null;
      const nonHate = ref.total - ref.hate;
      return { rate: (nonHate / ref.total) * loveOfNonHate, total: ref.total };
    };
    loveDeltaEl.innerHTML = [
      baselines.prior_period ? formatDeltaBQ(loveRate, toLoveRef(baselines.prior_period), 'prior period', true) : null,
      baselines.rolling_30d  ? formatDeltaBQ(loveRate, toLoveRef(baselines.rolling_30d),  '30d avg',      true) : null,
      baselines.rolling_12mo ? formatDeltaBQ(loveRate, toLoveRef(baselines.rolling_12mo), '12mo avg',     true) : null,
      baselines.year_ago && baselines.year_ago.total >= 20
        ? formatDeltaBQ(loveRate, toLoveRef(baselines.year_ago), 'year ago', true) : null
    ].filter(Boolean).join('');
  }

  // Threat level
  let threat, desc, cls;
  if (rate < 0.10) { threat = 'ALL CLEAR'; desc = 'The Force is strong'; cls = 'threat--low'; }
  else if (rate < 0.15) { threat = 'ELEVATED'; desc = 'Disturbance in the Force'; cls = 'threat--moderate'; }
  else if (rate < 0.20) { threat = 'HIGH'; desc = 'Dark Side rising'; cls = 'threat--high'; }
  else { threat = 'CRITICAL'; desc = 'The Dark Side dominates'; cls = 'threat--critical'; }

  const threatEl = document.getElementById('threatLevel');
  threatEl.textContent = threat;
  threatEl.className = 'card__value ' + cls;
  document.getElementById('threatDesc').textContent = desc;
}

// invertColor: for love rate, up = good (green), down = bad (red)
function formatDeltaBQ(currentRate, ref, label, invertColor = false) {
  if (!ref || !ref.total || ref.total < 20) return '';
  const pp = (currentRate - ref.rate) * 100;
  if (Math.abs(pp) < 0.05) return ''; // Flat — skip
  const goingUp = pp > 0;
  const isBad = invertColor ? !goingUp : goingUp;
  const cls = isBad ? 'delta--up' : 'delta--down';
  const arrow = goingUp ? '▲' : '▼';
  const sign = goingUp ? '+' : '';
  return `<span class="delta-badge ${cls}">${arrow} ${sign}${pp.toFixed(1)}pp <span class="delta-label">${label}</span></span>`;
}

// --- Trend Chart ---
function updateTrendChart(trend, rollingBaselines) {
  const ctx = document.getElementById('trendChart').getContext('2d');

  if (state.trendChart) state.trendChart.destroy();

  // Only show last 52 weeks for readability, but keep all for context
  const display = trend.slice(-52);

  const labels = display.map(t => formatWeekLabel(t.week));

  const datasets = [
    // Main bars — current hate rate per week
    {
      type: 'bar',
      label: 'Hate It Rate',
      data: display.map(t => +(t.hateRate * 100).toFixed(2)),
      backgroundColor: display.map(t =>
        t.total < 30         ? 'rgba(100,120,150,0.35)' :  // low volume — gray
        t.hateRate > 0.18    ? 'rgba(255,45,45,0.85)'   :
        t.hateRate > 0.14    ? 'rgba(255,45,45,0.55)'   :
                               'rgba(255,45,45,0.35)'
      ),
      borderColor: 'rgba(255,45,45,0.8)',
      borderWidth: 1,
      borderRadius: 2,
      order: 4
    },
    // 4-week trailing average line
    {
      type: 'line',
      label: '4-Week Avg',
      data: display.map(t => t.trailing4wAvg != null ? +(t.trailing4wAvg * 100).toFixed(2) : null),
      borderColor: 'rgba(0,180,255,0.7)',
      borderWidth: 2,
      borderDash: [4, 3],
      pointRadius: 0,
      pointHoverRadius: 4,
      fill: false,
      tension: 0.4,
      spanGaps: true,
      order: 2
    },
    // Year-ago same week — ghost line
    {
      type: 'line',
      label: 'Year Ago',
      data: display.map(t => t.yearAgoRate != null ? +(t.yearAgoRate * 100).toFixed(2) : null),
      borderColor: 'rgba(255,179,0,0.5)',
      borderWidth: 1.5,
      borderDash: [6, 4],
      pointRadius: 0,
      pointHoverRadius: 4,
      fill: false,
      tension: 0.4,
      spanGaps: false,
      order: 3
    }
  ];

  // Flat reference lines from BQ baselines
  if (rollingBaselines) {
    if (rollingBaselines.rolling_30d && rollingBaselines.rolling_30d.total >= 20) {
      const r = rollingBaselines.rolling_30d.rate * 100;
      datasets.push({
        type: 'line', label: '30d Baseline',
        data: display.map(() => +r.toFixed(2)),
        borderColor: 'rgba(0,230,118,0.5)', borderWidth: 1.5,
        borderDash: [6, 4], pointRadius: 0, fill: false, order: 1
      });
    }
    if (rollingBaselines.rolling_12mo && rollingBaselines.rolling_12mo.total >= 20) {
      const r = rollingBaselines.rolling_12mo.rate * 100;
      datasets.push({
        type: 'line', label: '12mo Baseline',
        data: display.map(() => +r.toFixed(2)),
        borderColor: 'rgba(0,230,118,0.25)', borderWidth: 1,
        borderDash: [10, 5], pointRadius: 0, fill: false, order: 1
      });
    }
  }

  state.trendChart = new Chart(ctx, {
    type: 'bar',
    data: { labels, datasets },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: {
          display: true,
          position: 'top',
          align: 'end',
          labels: {
            color: '#6a88b0',
            font: { size: 10 },
            boxWidth: 20,
            padding: 10,
            usePointStyle: true
          }
        },
        tooltip: {
          callbacks: {
            title: (items) => {
              if (!items.length) return '';
              const t = display[items[0].dataIndex];
              return t ? formatWeekLabel(t.week) : items[0].label;
            },
            label: (ctx) => {
              if (ctx.parsed.y == null) return null;
              return `${ctx.dataset.label}: ${ctx.parsed.y.toFixed(1)}%`;
            },
            afterBody: (items) => {
              const bar = items.find(i => i.dataset.label === 'Hate It Rate');
              if (bar && display[bar.dataIndex]) {
                const t = display[bar.dataIndex];
                const volNote = t.total < 30 ? ' ⚠ low vol' : '';
                return [`${t.hateCount} hate of ${t.total} rated${volNote}`];
              }
              return [];
            }
          }
        }
      },
      scales: {
        y: {
          beginAtZero: false,
          ticks: { callback: v => v + '%', color: '#6a88b0', font: { size: 11 } },
          grid: { color: 'rgba(0, 180, 255, 0.06)' }
        },
        x: {
          ticks: { color: '#6a88b0', font: { size: 10 }, maxTicksLimit: 20 },
          grid: { display: false }
        }
      }
    }
  });

  // Add explainer after the chart
  const container = document.getElementById('trendChart').closest('.chart-container');
  removeExplainer(container);
  container.insertAdjacentHTML('beforeend', EXPLAINERS.trend);
}

// --- Distribution Chart ---
function updateDistChart(baseline) {
  const ctx = document.getElementById('distChart').getContext('2d');

  if (state.distChart) state.distChart.destroy();

  state.distChart = new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: ['Hate It (1-2)', 'Neutral (3)', 'Love It (4-5)'],
      datasets: [{
        data: [baseline.hateCount, baseline.neutralCount, baseline.loveCount],
        backgroundColor: ['rgba(239, 68, 68, 0.8)', 'rgba(245, 158, 11, 0.8)', 'rgba(34, 197, 94, 0.8)'],
        borderColor: ['#ef4444', '#f59e0b', '#22c55e'],
        borderWidth: 2
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      cutout: '60%',
      plugins: {
        legend: {
          position: 'bottom',
          labels: { color: '#8899b3', padding: 12, font: { size: 11 } }
        },
        tooltip: {
          callbacks: {
            label: (ctx) => {
              const total = ctx.dataset.data.reduce((a, b) => a + b, 0);
              const pct = ((ctx.parsed / total) * 100).toFixed(1);
              return `${ctx.label}: ${ctx.parsed.toLocaleString()} (${pct}%)`;
            }
          }
        }
      }
    }
  });

  const container = document.getElementById('distChart').closest('.chart-container');
  removeExplainer(container);
  container.insertAdjacentHTML('beforeend', EXPLAINERS.distribution);
}

// --- Driver Table ---
function updateDriverTable(data, dimension) {
  const tbody = document.getElementById('driverTableBody');
  const dimLabel = getDimensionLabel(dimension);

  // Update section title
  const section = document.querySelector('.drivers-section .section-title');
  section.innerHTML = `⚡ Top Dark Side Agents by ${dimLabel} — Ranked by Threat`;

  if (!data.drivers || data.drivers.length === 0) {
    tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;color:var(--text-muted);padding:24px;">No data for this selection</td></tr>';
    return;
  }

  tbody.innerHTML = data.drivers.map((d, i) => {
    const rateWidth = Math.min(d.hateRate * 500, 100);
    const liftPct = (d.lift * 100).toFixed(1);
    const liftClass = d.lift > 0 ? 'lift-positive' : 'lift-negative';
    const liftSign = d.lift > 0 ? '+' : '';
    const sigBadge = d.significant
      ? (d.direction === 'above' ? '<span class="badge badge--sig">⚠️ Significant</span>' : '<span class="badge badge--good">✅ Significant</span>')
      : '<span class="badge badge--not">Not significant</span>';
    const rowClass = d.direction === 'above' ? 'above' : 'below';

    // Determine sub-dimension for drill-down
    const subDim = getSubDimension(dimension);

    return `<tr class="${rowClass}">
      <td>${i + 1}</td>
      <td><strong>${escapeHtml(d.value)}</strong></td>
      <td>
        <span class="rate-bar rate-bar--hate" style="width:${rateWidth}px"></span>
        ${(d.hateRate * 100).toFixed(1)}%
      </td>
      <td>${d.total.toLocaleString()}</td>
      <td><span class="${liftClass}">${liftSign}${liftPct}%</span></td>
      <td>${d.zScore.toFixed(2)}</td>
      <td>${sigBadge}</td>
      <td>${subDim ? `<button class="drill-btn" onclick="drillDown('${dimension}', '${escapeAttr(d.value)}', '${subDim}')">Drill ▸</button>` : ''}</td>
    </tr>`;
  }).join('');

  // Add explainer
  const section2 = document.getElementById('itemDriverSection');
  removeExplainer(section2);
  section2.insertAdjacentHTML('beforeend', EXPLAINERS.drivers);

  // Show enrichment for top driver if above baseline
  const topAbove = data.drivers.find(d => d.direction === 'above' && d.significant);
  if (topAbove) {
    showEnrichment(topAbove);
  } else {
    document.getElementById('enrichmentPanel').style.display = 'none';
  }
}

// --- Drill Down ---
function drillDown(dimension, value, subDimension) {
  state.drillStack.push({ dimension, value, subDimension });
  state.dimension = subDimension;
  document.getElementById('dimensionSelect').value = subDimension;
  loadDashboard();
}

function drillUp(toIndex) {
  state.drillStack = state.drillStack.slice(0, toIndex);
  if (state.drillStack.length > 0) {
    const last = state.drillStack[state.drillStack.length - 1];
    state.dimension = last.subDimension;
  } else {
    state.dimension = document.getElementById('dimensionSelect').value;
  }
  loadDashboard();
}

function updateDrillPath() {
  const container = document.getElementById('drillPath');
  if (state.drillStack.length === 0) {
    container.innerHTML = '';
    return;
  }

  let html = `<span class="drill-crumb" onclick="drillUp(0)">🏠 All</span>`;
  state.drillStack.forEach((item, i) => {
    html += `<span class="drill-sep">▸</span>`;
    html += `<span class="drill-crumb" onclick="drillUp(${i + 1})">${getDimensionLabel(item.dimension)}: ${escapeHtml(item.value)}</span>`;
  });
  container.innerHTML = html;
}

