function renderTenureCurve(boxDrivers) {
  const canvas = document.getElementById('bhTenureChart');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (bhState.charts.tenure) bhState.charts.tenure.destroy();

  const MIN_VOL = 30;
  const raw = (boxDrivers['package_num'] || []).filter(r => r.total >= MIN_VOL);
  if (!raw.length) {
    canvas.parentElement.innerHTML = '<div style="color:var(--text-muted);font-size:12px;padding:20px;text-align:center;">No box tenure data available.</div>';
    return;
  }

  // Group 10+ together
  const buckets = {};
  for (const r of raw) {
    const n   = parseInt(r.dim_value);
    const key = n >= 10 ? '10+' : String(n);
    if (!buckets[key]) buckets[key] = { hate: 0, total: 0 };
    buckets[key].hate  += r.hate;
    buckets[key].total += r.total;
  }

  // Sort: 1, 2, ... 9, 10+
  const labels = Object.keys(buckets).sort((a, b) => {
    if (a === '10+') return 1;
    if (b === '10+') return -1;
    return parseInt(a) - parseInt(b);
  });

  const rates    = labels.map(k => Math.round(buckets[k].hate / buckets[k].total * 1000) / 10);
  const overall  = raw.reduce((s, r) => s + r.hate, 0) / Math.max(raw.reduce((s, r) => s + r.total, 0), 1);
  const avgLine  = labels.map(() => Math.round(overall * 1000) / 10);

  // Find inflection: first box number where rate drops BELOW overall average
  const inflectionIdx = rates.findIndex(r => r < avgLine[0]);
  const inflectionLabel = inflectionIdx >= 0 ? labels[inflectionIdx] : null;

  bhState.charts.tenure = new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [
        {
          label: 'Box Hate Rate',
          data:  rates,
          borderColor: '#ef4444',
          backgroundColor: 'rgba(239,68,68,0.08)',
          pointBackgroundColor: rates.map((r, i) =>
            i === inflectionIdx ? '#22c55e' : r > avgLine[0] ? '#ef4444' : '#22c55e'
          ),
          pointRadius: 5,
          tension: 0.3,
          fill: true
        },
        {
          label: 'Overall Avg',
          data:  avgLine,
          borderColor: 'rgba(255,255,255,0.25)',
          borderDash: [5, 4],
          pointRadius: 0,
          tension: 0
        }
      ]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { labels: { color: '#94a3b8', font: { size: 11 } } },
        tooltip: {
          callbacks: {
            label: ctx => ` ${ctx.dataset.label}: ${ctx.parsed.y}%`
          }
        }
      },
      scales: {
        x: {
          title: { display: true, text: 'Box Number', color: '#64748b', font: { size: 11 } },
          ticks: { color: '#64748b' },
          grid:  { color: 'rgba(255,255,255,0.05)' }
        },
        y: {
          title: { display: true, text: 'Hate Rate %', color: '#64748b', font: { size: 11 } },
          ticks: { color: '#64748b', callback: v => v + '%' },
          grid:  { color: 'rgba(255,255,255,0.05)' },
          min: 0
        }
      }
    }
  });

  // Annotation below chart
  if (inflectionLabel) {
    const note = document.createElement('div');
    note.style.cssText = 'font-size:11px;color:var(--light-side);margin-top:6px;text-align:center;';
    note.textContent = `✅ Hate rate drops below average starting at box ${inflectionLabel}`;
    canvas.parentElement.appendChild(note);
  }
}

function renderSegmentGapTable(boxDrivers, profileData) {
  const tbody = document.getElementById('bhSegmentGapBody');
  if (!tbody) return;

  const MIN_VOL = 30;
  const DIM_LABELS = {
    package_num:   'Box Tenure',
    DayStyle:      'Day Style',
    EveningStyle:  'Evening Style',
    BottomFit:     'Bottom Fit',
    TopSize:       'Top Size',
    ShipAddrState: 'State',
    Stylist:       'Stylist',
    plan:          'Plan'
  };

  const gaps = [];

  // Process each boxDrivers dimension
  for (const [dim, label] of Object.entries(DIM_LABELS)) {
    let rows;
    if (dim === 'plan') {
      // From /api/customer-profiles
      rows = (profileData.byPlan || [])
        .filter(r => r.total >= MIN_VOL)
        .map(r => ({ dim_value: r.value, hate_rate: r.hateRate, total: r.total }));
    } else {
      rows = (boxDrivers[dim] || []).filter(r => r.total >= MIN_VOL);
    }

    if (rows.length < 2) continue; // need at least 2 to compute a gap

    const sorted = [...rows].sort((a, b) => a.hate_rate - b.hate_rate);
    const best   = sorted[0];
    const worst  = sorted[sorted.length - 1];
    const gap    = worst.hate_rate - best.hate_rate;

    // Format dim_value for package_num
    const fmtVal = (dim, val) => {
      if (dim === 'package_num') return val === '1' ? '1st Box' : `Box #${val}`;
      return escapeHtml(String(val));
    };

    gaps.push({
      label,
      bestVal:  fmtVal(dim, best.dim_value),
      bestRate: best.hate_rate,
      worstVal: fmtVal(dim, worst.dim_value),
      worstRate: worst.hate_rate,
      gap
    });
  }

  // Sort by gap descending
  gaps.sort((a, b) => b.gap - a.gap);

  if (!gaps.length) {
    tbody.innerHTML = `<tr><td colspan="6" style="text-align:center;color:var(--text-muted);padding:20px;">Not enough segment data for this date range.</td></tr>`;
    return;
  }

  tbody.innerHTML = gaps.map(g => {
    const gapPct   = (g.gap * 100).toFixed(1);
    const gapColor = g.gap > 0.10 ? 'var(--dark-side)' : g.gap > 0.05 ? '#f59e0b' : 'var(--text-muted)';
    const gapIcon  = g.gap > 0.10 ? '🔴' : g.gap > 0.05 ? '🟡' : '⚪';
    return `<tr>
      <td style="font-weight:600;">${g.label}</td>
      <td style="color:var(--light-side);">${g.bestVal}</td>
      <td style="color:var(--light-side);font-weight:600;">${(g.bestRate * 100).toFixed(1)}%</td>
      <td style="color:var(--dark-side);">${g.worstVal}</td>
      <td style="color:var(--dark-side);font-weight:600;">${(g.worstRate * 100).toFixed(1)}%</td>
      <td style="color:${gapColor};font-weight:600;">${gapIcon} ${gapPct}%</td>
    </tr>`;
  }).join('');
}

