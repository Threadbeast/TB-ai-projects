const SENTIMENT_COLORS = {
  love_it:    '#22c55e',
  mostly_me:  '#f59e0b',
  not_me:     '#ef4444',
  no_answer:  '#4b5563'
};
const SENTIMENT_LABELS = {
  love_it:   'Love It',
  mostly_me: 'Mostly Me',
  not_me:    'Not Me',
  no_answer: 'No Answer'
};

function renderSentimentBreakdown(enrichment) {
  const barEl    = document.getElementById('sentimentBar');
  const legendEl = document.getElementById('sentimentLegend');
  const labelEl  = document.getElementById('sentimentLabel');
  if (!barEl || !legendEl || !labelEl) return;

  const buckets = enrichment.styleAccuracyAll || [];
  const total   = buckets.reduce((s, b) => s + b.count, 0);

  if (total === 0) {
    barEl.innerHTML    = '<div style="color:var(--text-muted);font-size:12px;padding:4px 0;">No style accuracy data for this group.</div>';
    legendEl.innerHTML = '';
    labelEl.innerHTML  = '';
    return;
  }

  // Stacked bar
  barEl.innerHTML = buckets
    .filter(b => b.count > 0)
    .map(b => {
      const pct  = (b.pct * 100).toFixed(1);
      const col  = SENTIMENT_COLORS[b.bucket] || '#6b7280';
      const lbl  = SENTIMENT_LABELS[b.bucket] || b.bucket;
      return `<div style="flex:${b.pct};background:${col};min-width:${b.pct > 0.03 ? '24px' : '0'};
        display:flex;align-items:center;justify-content:center;
        color:#fff;font-size:10px;font-weight:600;cursor:default;transition:filter 0.15s;"
        onmouseover="this.style.filter='brightness(1.2)'"
        onmouseout="this.style.filter=''"
        title="${lbl}: ${pct}%">${b.pct > 0.06 ? pct + '%' : ''}</div>`;
    }).join('');

  // Legend
  legendEl.innerHTML = buckets
    .filter(b => b.count > 0)
    .map(b => {
      const pct = (b.pct * 100).toFixed(1);
      const col = SENTIMENT_COLORS[b.bucket] || '#6b7280';
      const lbl = SENTIMENT_LABELS[b.bucket] || b.bucket;
      return `<span style="display:flex;align-items:center;gap:4px;">
        <span style="display:inline-block;width:10px;height:10px;background:${col};border-radius:2px;"></span>
        ${escapeHtml(lbl)} ${pct}%
      </span>`;
    }).join('');

  // Auto-interpretation
  const notMe   = buckets.find(b => b.bucket === 'not_me')?.pct   || 0;
  const loveIt  = buckets.find(b => b.bucket === 'love_it')?.pct  || 0;
  const mostlyMe = buckets.find(b => b.bucket === 'mostly_me')?.pct || 0;

  let interpretation;
  if (notMe > 0.40) {
    interpretation = `⚠️ <strong>Style miss</strong> — ${(notMe*100).toFixed(0)}% of customers said items weren't their style at all. This is a curation signal, not a quality issue. Check if stylist profiling is aligned for this segment.`;
  } else if (loveIt > 0.60) {
    interpretation = `✅ <strong>Strong style match</strong> — ${(loveIt*100).toFixed(0)}% of customers loved the style choices. The hate is likely driven by quality or fit, not curation.`;
  } else if ((loveIt + mostlyMe) > 0.70) {
    interpretation = `👍 <strong>Good alignment</strong> — Style is landing well overall (${((loveIt+mostlyMe)*100).toFixed(0)}% love it or mostly their style). Focus investigation on quality and fit drivers.`;
  } else if (notMe > 0.25) {
    interpretation = `🔍 <strong>Mixed signals</strong> — ${(notMe*100).toFixed(0)}% style miss with some alignment. Worth reviewing profile accuracy and whether category fits the customer's stated preferences.`;
  } else {
    interpretation = `📊 <strong>Moderate alignment</strong> — Results are mixed. Dig into fit and quality breakdowns below for more signal.`;
  }
  labelEl.innerHTML = interpretation;
}

