// Aggregate boxTrend rows into period stats for a given date window
function computeBHPeriodStats(boxTrend, start, end) {
  const s = { new: {hate:0,love:0,neutral:0,total:0}, recurring: {hate:0,love:0,neutral:0,total:0} };
  for (const r of boxTrend) {
    if (start && r.week_start < start) continue;
    if (end   && r.week_start > end)   continue;
    const ct = r.customer_type === 'new' ? 'new' : 'recurring';
    s[ct].hate    += r.hate    || 0;
    s[ct].love    += r.love    || 0;
    s[ct].neutral += r.neutral || 0;
    s[ct].total   += r.total   || 0;
  }
  for (const ct of ['new','recurring']) {
    const c = s[ct];
    c.hate_rate = c.total > 0 ? c.hate / c.total : 0;
    c.love_rate = c.total > 0 ? c.love / c.total : 0;
  }
  return s;
}

// --- Summary Cards ---
// boxTrend = FULL unfiltered dataset (for rolling refs)
// start/end = the currently selected window
function renderBHCards(boxTrend, start, end) {
  const cur = computeBHPeriodStats(boxTrend, start, end);

  // Reference windows for delta badges (computed from full dataset)
  // Prior period: same span length immediately before start
  let priorRefNew = null, priorRefRec = null;
  let avg30dRefNew = null, avg30dRefRec = null;
  let yearAgoRefNew = null, yearAgoRefRec = null;

  if (start) {
    const spanMs   = end
      ? new Date(end + 'T00:00:00') - new Date(start + 'T00:00:00')
      : (bhState.bhDateDays > 0 ? bhState.bhDateDays : 91) * 86400000;
    const priorEndMs   = new Date(start + 'T00:00:00').getTime() - 86400000;
    const priorStartMs = priorEndMs - spanMs;
    const priorEnd   = new Date(priorEndMs).toISOString().split('T')[0];
    const priorStart = new Date(priorStartMs).toISOString().split('T')[0];
    priorRefNew = bhComputeRefByCT(boxTrend, priorStart, priorEnd, 'new');
    priorRefRec = bhComputeRefByCT(boxTrend, priorStart, priorEnd, 'recurring');

    // 30d rolling avg (prior 30 days before current window)
    const m30End   = priorEnd;
    const m30Start = new Date(new Date(start + 'T00:00:00').getTime() - 30 * 86400000).toISOString().split('T')[0];
    avg30dRefNew = bhComputeRefByCT(boxTrend, m30Start, m30End, 'new');
    avg30dRefRec = bhComputeRefByCT(boxTrend, m30Start, m30End, 'recurring');

    // Year-ago same window
    const yaStart = new Date(new Date(start + 'T00:00:00').getTime() - 365 * 86400000).toISOString().split('T')[0];
    const yaEnd   = end ? new Date(new Date(end + 'T00:00:00').getTime() - 365 * 86400000).toISOString().split('T')[0] : priorEnd;
    yearAgoRefNew = bhComputeRefByCT(boxTrend, yaStart, yaEnd, 'new');
    yearAgoRefRec = bhComputeRefByCT(boxTrend, yaStart, yaEnd, 'recurring');
  }

  function setVal(id, rate) {
    const el = document.getElementById(id);
    if (el) el.textContent = (rate * 100).toFixed(1) + '%';
  }
  function setDeltas(id, curRate, priorRef, avg30Ref, yearAgoRef, field, invertColor) {
    const el = document.getElementById(id);
    if (!el) return;
    el.innerHTML = [
      priorRef   ? formatBHDelta(curRate, priorRef[field],   'vs prior',   invertColor) : '',
      avg30Ref   ? formatBHDelta(curRate, avg30Ref[field],   '30d avg',    invertColor) : '',
      yearAgoRef ? formatBHDelta(curRate, yearAgoRef[field], 'year ago',   invertColor) : ''
    ].filter(Boolean).join('');
  }

  setVal('bh-hate-new', cur.new.hate_rate);
  setVal('bh-hate-rec', cur.recurring.hate_rate);
  setDeltas('bh-hate-new-delta', cur.new.hate_rate, priorRefNew, avg30dRefNew, yearAgoRefNew, 'hate_rate', false);
  setDeltas('bh-hate-rec-delta', cur.recurring.hate_rate, priorRefRec, avg30dRefRec, yearAgoRefRec, 'hate_rate', false);

  setVal('bh-love-new', cur.new.love_rate);
  setVal('bh-love-rec', cur.recurring.love_rate);
  setDeltas('bh-love-new-delta', cur.new.love_rate, priorRefNew, avg30dRefNew, yearAgoRefNew, 'love_rate', true);
  setDeltas('bh-love-rec-delta', cur.recurring.love_rate, priorRefRec, avg30dRefRec, yearAgoRefRec, 'love_rate', true);

  const totalNew = cur.new.total, totalRec = cur.recurring.total;
  document.getElementById('bh-total').textContent = (totalNew + totalRec).toLocaleString();
  document.getElementById('bh-total-sub').textContent =
    `${totalNew.toLocaleString()} new | ${totalRec.toLocaleString()} recurring`;

  // Threat level based on combined hate rate
  const combined = (cur.new.total + cur.recurring.total) > 0
    ? (cur.new.hate + cur.recurring.hate) / (cur.new.total + cur.recurring.total) : 0;
  const [level, desc, cls] =
    combined >= 0.20 ? ['CRITICAL', 'The Dark Side dominates',   'threat--critical'] :
    combined >= 0.15 ? ['HIGH',     'Dark Side rising',          'threat--high']     :
    combined >= 0.10 ? ['ELEVATED', 'Disturbance in the Force',  'threat--moderate'] :
                       ['ALL CLEAR','The Force is strong',       'threat--low'];
  document.getElementById('bh-threat').textContent = level;
  document.getElementById('bh-threat').className = `card__value ${cls}`;
  document.getElementById('bh-threat-desc').textContent = desc;
  const rateEl = document.getElementById('bh-threat-rate');
  if (rateEl) rateEl.textContent = `Combined hate rate: ${(combined * 100).toFixed(1)}%`;
}

// Helper: collect sorted unique weeks and build a keyed lookup from boxTrend or similar
function bhWeekLookup(rows, keyFn) {
  const lookup = {};
  for (const r of rows) {
    const wk = r.week_start;
    if (!lookup[wk]) lookup[wk] = {};
    keyFn(lookup[wk], r);
  }
  return lookup;
}

// Shared Chart.js line config for BH line charts
function bhLineDataset(label, data, color, dashed) {
  return {
    type: 'line', label, data,
    borderColor: color,
    borderWidth: dashed ? 1.5 : 2,
    borderDash: dashed ? [5, 4] : [],
    pointRadius: 2, pointHoverRadius: 5,
    fill: false, tension: 0.3, spanGaps: true
  };
}

