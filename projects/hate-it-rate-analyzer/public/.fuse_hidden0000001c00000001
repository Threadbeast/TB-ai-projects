function renderBrandCategoryHeatmap(data) {
  const container = document.getElementById('brandCatHeatmap');
  if (!container) return;

  const { cells, brands, categories } = data;
  if (!brands.length || !categories.length) {
    container.innerHTML = '<p style="color:var(--text-muted);text-align:center;padding:24px;">No data available for this date range.</p>';
    return;
  }

  // Build a lookup: cell[brand][category] = {hateRate, hateCount, total}
  const lookup = {};
  for (const c of cells) {
    if (!lookup[c.brand]) lookup[c.brand] = {};
    lookup[c.brand][c.category] = c;
  }

  // Color scale: 0% = near-transparent navy, 25%+ = dark red
  function cellBg(rate) {
    const t = Math.min(rate / 0.25, 1);
    const r = Math.round(20  + t * (155 - 20));
    const g = Math.round(35  + t * (0   - 35));
    const b = Math.round(55  + t * (0   - 55));
    const a = (0.18 + t * 0.82).toFixed(2);
    return `rgba(${r},${g},${b},${a})`;
  }

  const cellW  = 68;
  const labelW = 140;
  const gap    = 2;
  const cols   = categories.length;

  let html = `<div style="
    display:grid;
    grid-template-columns:${labelW}px ${Array(cols).fill(cellW + 'px').join(' ')};
    gap:${gap}px;
    min-width:${labelW + cols * (cellW + gap)}px;
    font-size:11px;
  ">`;

